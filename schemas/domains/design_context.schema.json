{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendatasheet.dev/schemas/domains/design_context/1.0",
  "title": "Design Context Domain",
  "description": "Design guidance including external components, equations, layout hints, supply recommendations, and topology hints.",
  "type": "object",
  "properties": {
    "recommended_external_components": {
      "type": "array",
      "description": "List of recommended external components for the design.",
      "items": {
        "type": "object",
        "properties": {
          "component": { "type": "string" },
          "value": { "type": ["string", "null"] },
          "purpose": { "type": ["string", "null"] },
          "conditions": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "component_value_hints": {
      "type": "array",
      "description": "Captured value clusters from application pages.",
      "items": {
        "type": "object",
        "properties": {
          "values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source_page": { "type": ["integer", "null"] },
          "snippet": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "design_range_hints": {
      "type": "array",
      "description": "Named operating ranges captured from design pages.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": ["string", "null"] },
          "min": { "type": ["number", "null"] },
          "max": { "type": ["number", "null"] },
          "unit": { "type": ["string", "null"] },
          "source_page": { "type": ["integer", "null"] },
          "snippet": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "design_equation_hints": {
      "type": "array",
      "description": "Design equations and formulas for component selection.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": ["string", "null"] },
          "equation": { "type": "string" },
          "variables": { "type": "object", "additionalProperties": true },
          "description": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "design_formulas": {
      "type": "array",
      "description": "Structured design formulas derived from application sections or overrides.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": ["string", "null"] },
          "formula": { "type": "string" },
          "formula_latex": { "type": ["string", "null"] },
          "variables": { "type": "object", "additionalProperties": true },
          "purpose": { "type": ["string", "null"] },
          "category": { "type": ["string", "null"] },
          "source": { "type": ["object", "null"], "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "typical_application": {
      "type": "object",
      "description": "Structured typical application circuit summary.",
      "properties": {
        "figure": { "type": ["string", "null"] },
        "page": { "type": ["integer", "null"] },
        "title": { "type": ["string", "null"] },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "designator": { "type": ["string", "null"] },
              "type": { "type": ["string", "null"] },
              "connection": {
                "type": "array",
                "items": { "type": "string" }
              },
              "typical_value": { "type": ["string", "number", "null"] },
              "purpose": { "type": ["string", "null"] },
              "related_formula": { "type": ["string", "null"] }
            },
            "additionalProperties": true
          }
        },
        "design_example": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "application_notes": {
      "type": "array",
      "description": "Structured application notes, warnings, and design recommendations.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": ["string", "null"] },
          "category": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] },
          "rationale": { "type": ["string", "null"] },
          "consequence": { "type": ["string", "null"] },
          "severity": { "type": ["string", "null"] },
          "related_parameters": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source": { "type": ["object", "null"], "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "configuration_mappings": {
      "type": "array",
      "description": "Configuration pin mappings and resistor-table encodings.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "design_recommendations": {
      "type": "array",
      "description": "Structured design recommendations and table-derived guidance.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "layout_hints": {
      "type": "array",
      "description": "PCB layout recommendations and constraints.",
      "items": {
        "type": "object",
        "properties": {
          "hint": { "type": "string" },
          "severity": { "enum": ["ERROR", "WARNING", "INFO"] },
          "applies_to": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "supply_recommendations": {
      "type": "array",
      "description": "Power supply design recommendations.",
      "items": {
        "type": "object",
        "properties": {
          "rail": { "type": "string" },
          "voltage": { "$ref": "#/$defs/param_value" },
          "current": { "$ref": "#/$defs/param_value" },
          "notes": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "topology_hints": {
      "type": "array",
      "description": "Circuit topology recommendations.",
      "items": {
        "type": "object",
        "properties": {
          "topology": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "conditions": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "origin": { "$ref": "#/$defs/origin_metadata" }
        },
        "additionalProperties": true
      }
    },
    "design_pages": {
      "type": "object",
      "description": "Metadata about design-relevant datasheet pages.",
      "properties": {
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "page": { "type": "integer" },
              "title": { "type": ["string", "null"] },
              "content_type": { "type": ["string", "null"] },
              "origin": { "$ref": "#/$defs/origin_metadata" }
            },
            "additionalProperties": true
          }
        },
        "total_pages": { "type": "integer" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "origin_metadata": {
      "description": "Evidence boundary for a design-context item: source fact, deterministic inference, model inference, manual override, or source recommendation.",
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "source_fact",
            "deterministic_inference",
            "model_inference",
            "manual_override",
            "source_recommendation"
          ]
        },
        "method": { "type": ["string", "null"] },
        "source_page": { "type": ["integer", "null"] },
        "source_field": { "type": ["string", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "param_value": {
      "description": "A numeric parameter with optional min/typ/max/unit/conditions",
      "type": "object",
      "properties": {
        "parameter": { "type": ["string", "null"] },
        "symbol": { "type": ["string", "null"] },
        "min": { "type": ["number", "null"] },
        "typ": { "type": ["number", "null"] },
        "max": { "type": ["number", "null"] },
        "value": { "type": ["number", "string", "null"] },
        "unit": { "type": ["string", "null"] },
        "conditions": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  }
}
