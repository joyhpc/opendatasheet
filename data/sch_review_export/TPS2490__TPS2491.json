        },
        "3": {
          "name": "PROG",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Power-limit setting input",
          "unused_treatment": null
        },
        "4": {
          "name": "TIMER",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
