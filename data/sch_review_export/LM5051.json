{
  "_schema": "sch-review-device/1.0",
  "_type": "normal_ic",
  "mpn": "LM5051",
  "manufacturer": "Texas Instruments",
  "category": "Other",
  "description": "Low Side OR-ing FET Controller",
  "packages": {
    "8-Lead SOIC": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "LINE",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply pin to bias the internal 12V zener shunt regulator at the VCC pin through an internal 50 kΩ series resistor.",
          "unused_treatment": null
        },
        "2": {
          "name": "VCC",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Connection to the internal 12V zener shunt voltage regulator. Requires bypass capacitor to VSS.",
          "unused_treatment": null
        },
        "3": {
          "name": "OFF",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "FET Test Mode control input. Logic high turns off the external MOSFET. Internal pull-down.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "nFGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open drain output for the FET Test circuit. Active low indicates forward voltage > 260 mV typical.",
          "unused_treatment": null
        },
        "5": {
          "name": "INP/VSS",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Negative supply voltage connection and MOSFET voltage sense connected to the external MOSFET common source connection.",
          "unused_treatment": null
        },
        "7": {
          "name": "INP/VSS",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Negative supply voltage connection and MOSFET voltage sense connected to the external MOSFET common source connection.",
          "unused_treatment": null
        },
        "6": {
          "name": "INN",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Voltage sense connection to the external MOSFET Drain pin.",
          "unused_treatment": null
        },
        "8": {
          "name": "GATE",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Gate drive for the external N-Channel MOSFET.",
          "unused_treatment": null
        }
      }
    }
  },
