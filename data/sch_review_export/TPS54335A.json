  "mpn": "TPS54335A",
  "manufacturer": "Texas Instruments",
  "category": "Buck",
  "description": "4.5-V to 28-V Input, 3-A Output, Synchronous Step-Down DC-DC Converter",
  "packages": {
    "SO PowerPAD (8)": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "BOOT",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "A bootstrap capacitor is required between the BOOT and PH pins. If the voltage on this capacitor is below the minimum required by the output device, the output is forced to switch off until the capacitor is refreshed.",
          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "This pin is the 4.5- to 28-V input supply voltage.",
          "unused_treatment": null
        },
        "3": {
          "name": "PH",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "The PH pin is the source of the internal high-side power MOSFET.",
          "unused_treatment": null
        },
        "4": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground connection.",
          "unused_treatment": null
        },
        "5": {
          "name": "VSENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "This pin is the inverting node of the transconductance (gm) error amplifier.",
          "unused_treatment": null
        },
        "6": {
          "name": "COMP",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "This pin is the error-amplifier output and the input to the output switch-current comparator. Connect frequency compensation components to this pin.",
          "unused_treatment": null
        },
        "7": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "This pin is the enable pin. Float the EN pin to enable.",
          "unused_treatment": "FLOAT"
        },
        "8": {
          "name": "RT",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Connect the RT pin to an external timing resistor to adjust the switching frequency of the device (TPS54335A and TPS54335-1A). (also: SS — The SS pin is the soft-start and tracking pin. An external capacitor connected to this pin sets the internal voltage-reference rise time (TPS54336A).)",
          "unused_treatment": null
        },
        "EP": {
          "name": "Exposed Thermal Pad",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "For proper operation, connect the GND pin to the exposed thermal pad. This thermal pad should be connected to any internal PCB ground plane using multiple vias for good thermal performance.",
          "unused_treatment": null
        }
      }
    },
