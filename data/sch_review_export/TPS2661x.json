  "manufacturer": "Texas Instruments",
  "category": "Other",
  "description": "50-V, Universal 4–20 mA, ±20-mA Current Loop Protector With Input and Output Miswiring Protection",
  "packages": {
    "SOT-23-8": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Reference ground for all internal voltages. Connect to GND of the ±Vs supply.",
          "unused_treatment": null
        },
        "2": {
          "name": "MODE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Mode selection pin for overload response. Sets current limit to IOL, 2 × IOL, or 2 × IOL with extended IOL expiry time.",
          "unused_treatment": "FLOAT"
        },
        "3": {
          "name": "-Vs",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Negative supply for dual supply configurations. Connect to GND when used in a single supply configuration.",
          "unused_treatment": null
        },
        "4": {
          "name": "IN",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Signal/power input",
          "unused_treatment": null
        },
        "5": {
          "name": "OUT",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Signal/power output",
          "unused_treatment": null
        },
        "6": {
          "name": "+Vs",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Positive supply for powering the device",
          "unused_treatment": null
        },
        "7": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable control. Pull EN low to turn off the device. EN has internal an pullup and it can be left floating to enable the device. (also: VSNS — Supply sensing input for transition to loop power mode. If not used, this pin can be left open or floating.)",
          "unused_treatment": "FLOAT"
        },
        "8": {
          "name": "SGOOD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Signal good indicator pin. Whenever the device is within normal operating condition, SGOOD shows low indicating signal is good to read.",
          "unused_treatment": null
        }
      }
    }
  },
