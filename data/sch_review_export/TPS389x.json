  "description": "Single-Channel Adjustable Voltage Supervisor in Ultra-Small USON Package",
  "packages": {
    "USON-6": {
      "pin_count": 6,
      "pins": {
        "5": {
          "name": "CT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Capacitor-adjustable delay input. Connecting this pin to a ground referenced capacitor sets the delay time.",
          "unused_treatment": null
        },
        "1": {
          "name": "ENABLE",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Active high enable input. Driving ENABLE low immediately makes SENSE_OUT go low. (also: ENABLE_BAR — Active low enable input. Driving ENABLE_BAR high immediately makes SENSE_OUT_BAR go high.)",
          "unused_treatment": null
        },
        "2": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground connection.",
          "unused_treatment": null
        },
        "3": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Input pin connected to the voltage that is monitored with the use of an external resistor.",
          "unused_treatment": null
        },
        "4": {
          "name": "SENSE_OUT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Active high sense output. Open-drain or push-pull output that is driven low when SENSE falls below threshold. (also: SENSE_OUT_BAR — Active low sense output. Open-drain or push-pull output that is driven high when SENSE falls below threshold.)",
          "unused_treatment": null
        },
        "6": {
          "name": "VCC",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Supply voltage input (1.7 V to 6.5 V).",
          "unused_treatment": null
        }
      }
    }
  },
