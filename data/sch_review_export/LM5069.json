    "VSSOP-10": {
      "pin_count": 10,
      "pins": {
        "1": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current sense input for measuring voltage across the current sense resistor (RS)",
          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Positive supply input",
          "unused_treatment": null
        },
        "3": {
          "name": "UVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Undervoltage lockout and remote shutdown control",
          "unused_treatment": null
        },
        "4": {
          "name": "OVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Overvoltage lockout",
          "unused_treatment": null
        },
        "5": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Circuit ground",
          "unused_treatment": null
        },
        "6": {
          "name": "TIMER",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Timing capacitor connection for insertion delay and fault timeout period",
          "unused_treatment": null
        },
        "7": {
          "name": "PWR",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Power limit set via external resistor to set maximum power dissipation",
          "unused_treatment": null
        },
        "8": {
          "name": "PGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Power Good indicator (open drain output)",
          "unused_treatment": null
        },
        "9": {
          "name": "OUT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output feedback for sensing external MOSFET VDS voltage",
          "unused_treatment": null
        },
        "10": {
          "name": "GATE",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Gate drive output for external N-channel MOSFET",
          "unused_treatment": null
        }
      }
    }
  },
