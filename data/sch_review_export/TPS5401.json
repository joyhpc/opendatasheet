{
  "_schema": "device-knowledge/2.0",
  "_type": "normal_ic",
  "_layers": [
    "L0_skeleton",
    "L1_electrical"
  ],
  "mpn": "TPS5401",
  "manufacturer": "Texas Instruments",
  "category": "Buck",
  "description": "0.5-A, 42-V Input, Step-Down Converter",
  "packages": {
    "MSOP-10": {
      "pin_count": 11,
      "pins": {
        "1": {
          "name": "BOOT",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "A bootstrap capacitor is required between BOOT and PH. If the voltage on this capacitor is below the minimum required by the output device, the output is forced to switch off until the capacitor is refreshed.",
          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input supply voltage, 3.5 V to 42 V.",
          "unused_treatment": null
        },
        "3": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable pin, internal pullup current source. Pull below 1.2 V to disable. Float to enable. Adjust the input undervoltage lockout with two resistors.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "SS/TR",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Slow-start and tracking. An external capacitor connected to this pin sets the output rise time. Because the voltage on this pin overrides the internal reference, it can be used for tracking and sequencing.",
          "unused_treatment": null
        },
        "5": {
          "name": "RT/CLK",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Resistor timing and external clock. An internal amplifier holds this pin at a fixed voltage when using an external resistor to ground to set the switching frequency. If the pin is pulled above the PLL upper threshold, a mode change occurs and the pin becomes a synchronization input.",
          "unused_treatment": null
        },
        "6": {
          "name": "PWRGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "An open-drain output; asserts low if output voltage is low due to thermal shutdown, dropout, overvoltage or EN shutdown.",
          "unused_treatment": null
        },
        "7": {
          "name": "VSENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Inverting node of the transconductance (gm) error amplifier.",
          "unused_treatment": null
        },
        "8": {
          "name": "COMP",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Error amplifier output, and input to the output switch current comparator. Connect frequency compensation components to this pin.",
          "unused_treatment": null
        },
        "9": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground",
          "unused_treatment": null
        },
        "10": {
          "name": "PH",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "The source of the internal high-side power MOSFET",
          "unused_treatment": null
        },
        "11": {
          "name": "Thermal pad",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "GND pin must be electrically connected to the thermal pad on the printed circuit board for proper operation.",
          "unused_treatment": null
        }
      }
    }
  },
