  "description": "600 mA, Ultralow Noise, High PSRR, RF Linear Regulator",
  "packages": {
    "8-Lead LFCSP": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "VREG",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulated input supply voltage to LDO amplifier. Bypass VREG to GND with a 10 µF or greater capacitor.",
          "unused_treatment": null
        },
        "2": {
          "name": "VOUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulated output voltage. Bypass VOUT to GND with a 10 µF or greater capacitor.",
          "unused_treatment": null
        },
        "3": {
          "name": "BYP",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Low noise bypass capacitor. Connect a 1 µF capacitor from the BYP pin to GND to reduce noise. Do not connect a load to ground.",
          "unused_treatment": null
        },
        "4": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground connection.",
          "unused_treatment": null
        },
        "5": {
          "name": "REF_SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Reference sense. Connect Pin 5 to the REF pin. Do not connect Pin 5 to VOUT or GND.",
          "unused_treatment": null
        },
        "6": {
          "name": "REF",
          "direction": "POWER_OUT",
          "signal_type": "ANALOG",
          "description": "Low noise reference voltage output. Bypass REF to GND with a 1 µF capacitor. Short REF_SENSE to REF for fixed output voltages. Do not connect a load to ground.",
          "unused_treatment": null
        },
        "7": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable. Drive EN high to turn on the regulator; drive EN low to turn off the regulator. For automatic startup, connect EN to VIN.",
          "unused_treatment": "VCC"
        },
        "8": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Regulator input supply voltage. Bypass VIN to GND with a 10 µF or greater capacitor.",
          "unused_treatment": null
        },
        "EP": {
          "name": "EP",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Exposed pad. Electrically connected to GND inside the package. Connect the EP to the ground plane on the board to ensure proper operation.",
