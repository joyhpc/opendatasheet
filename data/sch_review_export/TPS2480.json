    "VHYST_PG": {
      "parameter": "PG threshold hysteresis voltage",
      "min": null,
      "typ": 1.4,
      "max": null,
      "unit": "V",
      "conditions": "VSENSE = VVCC"
    },
    "tDPG": {
      "parameter": "PG deglitch delay",
      "min": 5,
      "typ": 9,
      "max": 15,
      "unit": "ms",
      "conditions": "VSENSE = VVCC"
    },
    "IOUT": {
      "parameter": "OUT Bias current (sinking)",
      "min": null,
      "typ": 8,
      "max": 20,
      "unit": "µA",
      "conditions": "VOUT = VVCC, VEN = Hi; sinking"
    },
    "IOUT_VOUT___GND__VEN___Lo__sourcing": {
      "parameter": "OUT Bias current (sourcing)",
      "min": null,
      "typ": 18,
      "max": 40,
      "unit": "µA",
      "conditions": "VOUT = GND; VEN = Lo; sourcing"
    },
    "VEN_H": {
      "parameter": "Threshold VEN going high",
      "min": 1.32,
      "typ": 1.35,
