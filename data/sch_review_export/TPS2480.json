      "parameter": "Large overload response time",
      "min": null,
      "typ": null,
      "max": 1.2,
      "unit": "µs",
      "conditions": "VPROG = 4 V; VOUT = VSENSE; V(VCC-SENSE): 0 rising to 200 mV; C(GATE-OUT) = 2 nF; V(GATE-OUT) = 1 V"
    },
    "ISOURCE": {
      "parameter": "Charge current (sourcing)",
      "min": 15.0,
      "typ": 25.0,
      "max": 34.0,
      "unit": "µA",
      "conditions": "VTIMER = 0 V"
    },
    "ISOURCE_VTIMER___0_V__TJ___25_C": {
      "parameter": "Charge current (sourcing) 25C",
      "min": 20.0,
      "typ": 25.0,
      "max": 30.0,
      "unit": "µA",
      "conditions": "VTIMER = 0 V; TJ = 25°C"
    },
    "ISINK": {
      "parameter": "Discharge current (sinking)",
      "min": 1.5,
      "typ": 2.5,
      "max": 3.7,
      "unit": "µA",
      "conditions": "VTIMER = 5 V"
    },
    "ISINK_VTIMER___5_V__TJ___25_C": {
      "parameter": "Discharge current (sinking) 25C",
      "min": 2.1,
      "typ": 2.5,
      "max": 3.1,
      "unit": "µA",
      "conditions": "VTIMER = 5 V; TJ = 25°C"
    },
    "DRETRY": {
      "parameter": "Fault retry duty cycle",
      "min": 0.5,
      "typ": 0.75,
      "max": 1.0,
      "unit": "%",
      "conditions": "TPS2481 only"
    },
    "IGATE": {
      "parameter": "GATE sourcing current",
      "min": 15,
      "typ": 22,
      "max": 35,
      "unit": "µA",
      "conditions": "VSENSE = VVCC; V(GATE-OUT) = 7 V; VEN = Hi"
    },
    "IGATE_VEN___Lo__VGATE___VVCC": {
      "parameter": "GATE sinking current (EN Lo)",
      "min": 1.8,
      "typ": 2.4,
      "max": 2.8,
      "unit": "mA",
      "conditions": "VEN = Lo; VGATE = VVCC"
    },
    "IGATE_VEN___Hi__VGATE___VVCC__V_VCC": {
      "parameter": "GATE sinking current (Overload)",
      "min": 75,
      "typ": 125,
      "max": 250,
      "unit": "mA",
      "conditions": "VEN = Hi; VGATE = VVCC; V(VCC-SENSE) > 200 mV"
    },
    "VGATE-OUT": {
      "parameter": "GATE output voltage",
      "min": 12,
      "typ": null,
      "max": 16,
      "unit": "V",
      "conditions": null
    },
    "tD_ON": {
      "parameter": "Propagation delay EN true to GATE high",
      "min": null,
      "typ": 25,
      "max": 40,
      "unit": "µs",
      "conditions": "VEN = 0 -> 2.5 V, 50% of VEN to 50% of VGATE, VOUT = VVCC, R(GATE-OUT) = 1 MOhm"
    },
    "tD_OFF": {
      "parameter": "Propagation delay EN false to GATE low",
      "min": null,
      "typ": 0.5,
      "max": 1,
      "unit": "µs",
      "conditions": "VEN = 2.5 V -> 0 V, 50% of VEN to 50% of VGATE, VOUT = VVCC, R(GATE-OUT) = 1 MΩ, tFALL < 0.1 µs"
    },
    "VPG_L": {
      "parameter": "PG Low voltage (2mA)",
      "min": null,
      "typ": 0.1,
      "max": 0.25,
      "unit": "V",
      "conditions": "IPG = 2 mA"
    },
    "VPG_L_IPG___4_mA": {
      "parameter": "PG Low voltage (4mA)",
      "min": null,
      "typ": 0.25,
      "max": 0.5,
      "unit": "V",
      "conditions": "IPG = 4 mA"
    },
    "VPGTL": {
      "parameter": "PG threshold voltage rising",
      "min": 0.8,
      "typ": 1.25,
      "max": 1.7,
      "unit": "V",
      "conditions": "VSENSE = VVCC; measure V(VCC-OUT)"
