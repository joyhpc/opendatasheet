      "parameter": "Current sense threshold with power limiting",
      "min": 17,
      "typ": 25,
      "max": 33,
      "unit": "mV",
      "conditions": "VPROG = 2.4 V; VOUT = 0 V or VPROG = 0.9 V; VOUT = 30 V; VVCC = 48 V"
