  "mpn": "ADM7172",
  "manufacturer": "Analog Devices",
  "category": "LDO",
  "description": "6.5 V, 2 A, Ultralow Noise, High PSRR, Fast Transient Response CMOS LDO",
  "packages": {
    "8-Lead LFCSP": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "VOUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulated Output Voltage. Bypass this pin to GND with a 4.7 µF or greater capacitor.",
          "unused_treatment": null
        },
        "2": {
          "name": "VOUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulated Output Voltage. Bypass this pin to GND with a 4.7 µF or greater capacitor.",
          "unused_treatment": null
        },
        "3": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Sense Input. Connect this pin as close as possible to the load for best load regulation. Use an external resistor divider to set the output voltage higher than the fixed output voltage.",
          "unused_treatment": null
        },
        "4": {
          "name": "SS",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Soft Start. A 1 nF external capacitor connected to SS results in a 1.0 ms start-up time.",
          "unused_treatment": null
        },
        "5": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Regulator Enable. Drive EN high to turn on the regulator; drive EN low to turn off the regulator.",
          "unused_treatment": "VCC"
        },
        "6": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground.",
          "unused_treatment": null
        },
        "7": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Regulator Input Supply. Bypass this pin to GND with a 4.7 µF or greater capacitor.",
          "unused_treatment": null
        },
        "8": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Regulator Input Supply. Bypass this pin to GND with a 4.7 µF or greater capacitor.",
          "unused_treatment": null
        },
        "9": {
          "name": "EP",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Exposed Pad. The exposed pad enhances thermal performance and is electrically connected to GND inside the package. Connect the exposed pad to the ground plane on the board.",
          "unused_treatment": "GND"
        }
      }
    }
  },
