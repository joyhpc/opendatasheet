  "mpn": "MAX9377/MAX9378",
  "manufacturer": "Maxim",
  "category": "Interface",
  "description": "Anything-to-LVPECL/LVDS Translators with Pin-Selectable Divide-by-Four",
  "packages": {
    "8-pin μMAX": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "SEL",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Frequency Divider Select Input. High = divide by four, low = no division. Internal 75kΩ pulldown to GND.",
          "unused_treatment": "FLOAT"
        },
        "2": {
          "name": "IN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Differential LVDS/Any Noninverting Input",
          "unused_treatment": null
        },
        "3": {
          "name": "IN_B",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Differential LVDS/Any Inverting Input",
          "unused_treatment": null
        },
        "4": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground",
          "unused_treatment": null
        },
        "5": {
          "name": "RST",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Frequency Divider Reset Input. Active high, asynchronous, reset. Internal 75kΩ pulldown to GND.",
          "unused_treatment": "FLOAT"
        },
        "6": {
          "name": "OUT_B",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Differential LVPECL (MAX9377) or LVDS (MAX9378) Inverting Output",
          "unused_treatment": null
        },
        "7": {
          "name": "OUT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Differential LVPECL (MAX9377) or LVDS (MAX9378) Noninverting Output",
          "unused_treatment": null
        },
        "8": {
          "name": "VCC",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Positive Supply. Bypass from VCC to GND with 0.1μF and 0.01μF ceramic capacitors.",
          "unused_treatment": null
        }
      }
    }
  },
