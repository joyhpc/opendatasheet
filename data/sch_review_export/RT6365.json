          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power input. The input voltage range is from 4V to 60V. Connect a suitable input capacitor between this pin and GND.",
          "unused_treatment": null
        },
        "3": {
          "name": "EN",
