          "description": "Enable control pin with internal pull-up current source. Float or provide a logic-high (≥ 1.2V) enables the converter; a logic-low forces the device into shutdown mode.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "SS/TR",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Soft-start and tracking control input. Connect a capacitor from SS to GND to set the soft-start period. Do Not leave this pin floating to avoid inrush current during power up.",
          "unused_treatment": "CUSTOM"
        },
        "5": {
          "name": "RT/SYNC",
          "direction": "INPUT",
