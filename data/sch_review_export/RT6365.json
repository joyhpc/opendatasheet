  "mpn": "RT6365",
  "manufacturer": "Richtek",
  "category": "Buck",
  "description": "60VIN, 5A, Asynchronous Step-Down Converter with Low Quiescent Current",
  "packages": {
    "SOP-8 (Exposed Pad)": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "BOOT",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Bootstrap capacitor connection node to supply the high-side gate driver. Connect a 0.1μF ceramic capacitor between this pin and the SW pin.",
          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power input. The input voltage range is from 4V to 60V. Connect a suitable input capacitor between this pin and GND.",
          "unused_treatment": null
        },
        "3": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable control pin with internal pull-up current source. Float or provide a logic-high (≥ 1.2V) enables the converter; a logic-low forces the device into shutdown mode.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "RT/SYNC",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Frequency setting and external synchronous signal input. Connect a resistor from this pin to GND to set the switching frequency. Tie to a clock source for synchronization to an external frequency.",
          "unused_treatment": null
        },
        "5": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense. Sense the output voltage at the FB pin through a resistive divider. The feedback reference voltage is 0.8V typically.",
          "unused_treatment": null
        },
        "6": {
          "name": "COMP",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Compensation node. Connect external compensation elements to this pin to stabilize the control loop.",
          "unused_treatment": null
        },
        "7": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground. Provide the ground return path for the control circuitry.",
          "unused_treatment": null
        },
        "8": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch node. SW is the switching node that supplies power to the output. Connect the output LC filter from SW to the output load.",
          "unused_treatment": null
        },
        "9": {
          "name": "PAD",
          "direction": "PASSIVE",
          "signal_type": "NONE",
          "description": "Exposed pad. The exposed pad is internally unconnected and must be soldered to a large PCB copper area for maximum power dissipation.",
          "unused_treatment": null
        }
      }
    },
    "WDFN-10L 4x4": {
      "pin_count": 11,
      "pins": {
        "1": {
          "name": "BOOT",
