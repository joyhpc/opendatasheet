          "unused_treatment": null
        },
        "10": {
          "name": "PGOOD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open-drain power-good indication output. Once being started-up, PGOOD will be pulled low to GND if any internal protection is triggered.",
          "unused_treatment": null
        },
        "11": {
          "name": "PAD",
          "direction": "PASSIVE",
          "signal_type": "NONE",
          "description": "Exposed pad. The exposed pad is internally unconnected and must be soldered to a large PCB copper area for maximum power dissipation.",
          "unused_treatment": null
        }
      }
