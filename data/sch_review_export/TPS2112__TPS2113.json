{
  "_schema": "sch-review-device/1.0",
  "_type": "normal_ic",
  "mpn": "TPS2112, TPS2113",
  "manufacturer": "Texas Instruments",
  "category": "Switch",
  "description": "Autoswitching Power Mux with low rDS(on) switches and adjustable current limit",
  "packages": {
    "TSSOP-8": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "STAT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open-drain status output. STAT is Hi-Z if the IN2 switch is ON. STAT pulls low if the IN1 switch is ON or if OUT is Hi-Z (i.e., EN is high).",
          "unused_treatment": null
        },
        "2": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Active-low enable input. TTL and CMOS compatible with an internal 1-µA pull-up.",
          "unused_treatment": null
        },
        "3": {
          "name": "VSNS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Voltage sense input. Connects OUT to IN1 if VSNS > 0.8 V; otherwise, OUT connects to the higher of IN1 and IN2.",
          "unused_treatment": null
        },
        "4": {
          "name": "ILIM",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current limit setting pin. A resistor from ILIM to GND sets the current limit.",
          "unused_treatment": null
        },
        "5": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground",
          "unused_treatment": null
        },
        "6": {
          "name": "IN2",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Secondary power switch input.",
          "unused_treatment": null
        },
        "7": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Power switch output.",
          "unused_treatment": null
        },
        "8": {
          "name": "IN1",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Primary power switch input.",
          "unused_treatment": null
        }
      }
    }
  },
  "absolute_maximum_ratings": {
    "VI": {
      "parameter": "Input voltage range",
      "min": -0.3,
      "max": 6,
      "unit": "V",
      "conditions": "All voltages are with respect to GND"
    },
    "VO": {
      "parameter": "Output voltage range",
      "min": -0.3,
      "max": 6,
      "unit": "V",
      "conditions": null
    },
    "IO(STAT)": {
      "parameter": "Output sink current",
      "min": null,
      "max": 5,
      "unit": "mA",
      "conditions": null
    },
    "IO": {
      "parameter": "Continuous output current",
      "min": null,
      "max": 0.9,
      "unit": "A",
      "conditions": "TPS2112"
    },
    "IO_TPS2113": {
      "parameter": "Continuous output current",
      "min": null,
      "max": 1.5,
      "unit": "A",
      "conditions": "TPS2113"
    },
    "TJ": {
      "parameter": "Operating virtual junction temperature range",
      "min": -40,
      "max": 125,
      "unit": "°C",
      "conditions": null
    },
    "Tstg": {
      "parameter": "Storage temperature range",
      "min": -65,
      "max": 150,
      "unit": "°C",
      "conditions": null
    }
  },
  "electrical_parameters": {
    "rDS(on)": {
      "parameter": "Drain-source on-state resistance",
      "min": null,
      "typ": 120,
      "max": 140,
      "unit": "mΩ",
      "conditions": "VI(IN1) = VI(IN2) = 5.0 V, IL = 500 mA"
    },
    "rDS(on)_VI_IN1____VI_IN2____5_0_V__IL": {
      "parameter": "Drain-source on-state resistance",
      "min": null,
      "typ": null,
      "max": 150,
      "unit": "mΩ",
      "conditions": "VI(IN1) = VI(IN2) = 5.0 V, IL = 500 mA"
    },
    "VIH": {
      "parameter": "High-level input voltage",
      "min": 2,
      "typ": null,
      "max": null,
      "unit": "V",
      "conditions": "Logic Inputs (EN)"
    },
    "VIL": {
      "parameter": "Low-level input voltage",
      "min": null,
      "typ": null,
      "max": 0.7,
      "unit": "V",
      "conditions": "Logic Inputs (EN)"
    },
    "IIN": {
      "parameter": "Input current",
      "min": 0.5,
      "typ": 1.4,
      "max": 5,
      "unit": "µA",
      "conditions": "EN = Low, source current"
    },
    "IIN1": {
      "parameter": "Supply current from IN1 (operating)",
      "min": null,
      "typ": 55,
      "max": 90,
      "unit": "µA",
      "conditions": "VI(VSNS) = 1.5 V, EN = Low (IN1 active), VI(IN1) = 5.5 V, VI(IN2) = 3.3 V, IO(OUT) = 0 A"
    },
    "IIN1(STBY)": {
      "parameter": "Quiescent current from IN1 (STANDBY)",
      "min": null,
      "typ": 0.5,
      "max": 2,
      "unit": "µA",
      "conditions": "EN = High (inactive), VI(IN1) = 5.5 V, VI(IN2) = 3.3 V, IO(OUT) = 0 A"
    },
    "IL": {
      "parameter": "Current limit accuracy",
      "min": 0.51,
      "typ": 0.63,
      "max": 0.8,
      "unit": "A",
      "conditions": "RILIM = 400 Ω"
    },
    "IL_RILIM___400": {
      "parameter": "Current limit accuracy",
      "min": 0.95,
      "typ": 1.25,
      "max": 1.56,
      "unit": "A",
      "conditions": "RILIM = 400 Ω"
    },
    "VIT(VSNS)": {
      "parameter": "VSNS threshold voltage",
      "min": 0.78,
      "typ": 0.8,
      "max": 0.82,
      "unit": "V",
      "conditions": "VI(VSNS) rising"
    },
    "VUVLO": {
      "parameter": "IN1 and IN2 UVLO",
      "min": 1.3,
      "typ": 1.35,
      "max": null,
      "unit": "V",
      "conditions": "Rising edge"
    },
    "TSD": {
      "parameter": "Thermal shutdown threshold",
      "min": null,
      "typ": 135,
      "max": null,
      "unit": "°C",
      "conditions": "TPS211x is in current limit"
    }
  },
  "drc_hints": {
    "vin_abs_max": {
      "value": 6,
      "unit": "V"
    },
    "iout_abs_max": {
      "value": 0.9,
      "unit": "A"
    }
  }
}