  "description": "500mA, Ultra-Low Dropout, Low Power, RF Linear Regulator",
  "packages": {
    "SOT-23-6": {
      "pin_count": 6,
      "pins": {
        "1": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input Voltage Supply Pin. It is recommended to use a 2.2μF or larger ceramic capacitor from VIN pin to ground.",
          "unused_treatment": null
        },
        "2": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground.",
          "unused_treatment": null
        },
        "3": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable Pin. Drive EN high to turn on the regulator. Drive EN low to turn off the regulator. The EN pin has an internal 0.03μA pull-down current source which ensures that the device is turned off when the EN pin is floated.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "BP",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Reference-Noise Bypass Pin. Bypass with an external capacitor CBP can reduce output noise to very low level.",
          "unused_treatment": null
        },
        "5": {
          "name": "NC",
          "direction": "NC",
          "signal_type": "NONE",
          "description": "Not Connected (fixed voltage version only). (also: ADJ — Feedback Input Pin (adjustable voltage version only). Connect this pin to the external resistor divider to adjust the output voltage.)",
          "unused_treatment": null
        },
        "6": {
          "name": "VOUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulator Output Pin. It is recommended to use an output capacitor with effective capacitance in the range of 1μF to 10μF.",
          "unused_treatment": null
        }
      }
    }
  },
