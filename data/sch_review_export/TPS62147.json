  "mpn": "TPS62147",
  "manufacturer": "Texas Instruments",
  "category": "Buck",
  "description": "High accuracy 3V to 17V 2A step-down converter with DCS-Control",
  "packages": {
    "VQFN-11 (RGX)": {
      "pin_count": 11,
      "pins": {
        "1": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply input. Make sure the input capacitor is connected as close as possible between pin VIN and GND.",
          "unused_treatment": null
        },
        "2": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch pin of the converter connected to the internal Power MOSFETs.",
          "unused_treatment": null
        },
        "3": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground pin.",
          "unused_treatment": null
        },
        "4": {
          "name": "AGND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Analog ground. Connect to GND.",
          "unused_treatment": null
        },
        "5": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Voltage feedback input. Connect resistive output voltage divider to this pin.",
          "unused_treatment": null
        },
        "6": {
          "name": "VOS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense pin. Connect directly to the positive pin of the output capacitor.",
          "unused_treatment": null
        },
        "7": {
          "name": "PG",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open drain power good output. Leave open or tie to GND if not used.",
          "unused_treatment": "FLOAT"
        },
        "8": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable pin of the device. Connect to logic low to disable the device. Pull high to enable the device. Do not leave this pin unconnected.",
          "unused_treatment": null
        },
        "9": {
          "name": "SS/TR",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Soft-start / Tracking pin. An external capacitor connected from this pin to GND defines the rise time for the internal reference voltage.",
          "unused_treatment": null
        },
        "10": {
          "name": "MODE",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "The device runs in PFM/PWM mode when this pin is pulled low. When the pin is pulled high, the device runs in forced PWM mode. Do not leave this pin unconnected.",
          "unused_treatment": null
        },
        "11": {
          "name": "FSEL",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Switching frequency setting pin. Pull to logic low for 1.25 MHz. Pull to logic high for 2.5 MHz. Do not leave FSEL unconnected.",
          "unused_treatment": null
        }
      }
    }
  },
