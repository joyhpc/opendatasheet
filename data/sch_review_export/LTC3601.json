  "manufacturer": "Linear Technology",
  "category": "Buck",
  "description": "1.5A, 15V Monolithic Synchronous Step-Down Regulator",
  "packages": {
    "QFN-16": {
      "pin_count": 17,
      "pins": {
        "1": {
          "name": "MODE/SYNC",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Mode Selection and External Synchronization Input Pin. Tie to GND for forced continuous mode, float or tie to INTVCC for Burst Mode. Can be driven by an external clock.",
          "unused_treatment": "FLOAT"
        },
        "2": {
          "name": "PGOOD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open-Drain Power Good Output Pin. Pulled to ground when FB is not within +/-8% of reference.",
          "unused_treatment": null
        },
        "3": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch Node Output Pin. Connect to the external inductor.",
          "unused_treatment": null
        },
        "4": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch Node Output Pin. Connect to the external inductor.",
          "unused_treatment": null
        },
        "6": {
          "name": "BOOST",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Boosted Floating Driver Supply Pin. Connect a bootstrap capacitor between this pin and SW.",
          "unused_treatment": null
        },
        "7": {
          "name": "INTVCC",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Internal 3.3V Regulator Output Pin. Decouple with a low ESR ceramic capacitor to PGND.",
          "unused_treatment": null
        },
        "8": {
          "name": "VON",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "On-Time Voltage Input Pin. Sets the voltage trip point for the on-time comparator.",
          "unused_treatment": null
        },
        "9": {
          "name": "SGND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Signal Ground Pin. Reference ground for feedback, compensation, and RT resistor. In MSE package, this is the exposed pad.",
          "unused_treatment": null
        },
        "10": {
          "name": "RT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Oscillator Frequency Program Pin. Connect a resistor to SGND to set frequency, or tie to INTVCC for 2MHz.",
          "unused_treatment": "CUSTOM"
        },
        "11": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output Voltage Feedback Pin. Connect to resistor divider to program output voltage.",
          "unused_treatment": null
        },
        "12": {
          "name": "ITH",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Error Amplifier Output and Switching Regulator Compensation Pin. Tie to INTVCC for internal compensation.",
          "unused_treatment": "CUSTOM"
        },
        "13": {
          "name": "TRACK",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output Voltage Tracking and Soft-Start Input Pin. Internal 1.4uA pull-up current.",
          "unused_treatment": null
        },
        "14": {
          "name": "RUN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Regulator Enable Pin. Above 1.25V enables, below 1V shuts down. Do not float.",
          "unused_treatment": "CUSTOM"
        },
        "15": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Main Power Supply Input Pins. Decouple to PGND with low ESR capacitor.",
          "unused_treatment": null
        },
        "16": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Main Power Supply Input Pins. Decouple to PGND with low ESR capacitor.",
