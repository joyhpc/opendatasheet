  "description": "60-V, 800-mA Industrial eFuse With Integrated Input and Output Reverse Polarity Protection",
  "packages": {
    "VSON-10": {
      "pin_count": 11,
      "pins": {
        "1": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input supply voltage",
          "unused_treatment": null
        },
        "2": {
          "name": "UVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Resistor programmable undervoltage lockout threshold setting input. Connect to IN via 1-MΩ resistor if unused.",
          "unused_treatment": "CUSTOM"
        },
        "3": {
          "name": "OVP",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Resistor programmable overvoltage protection threshold. Connect to RTN if unused.",
          "unused_treatment": "CUSTOM"
        },
        "4": {
          "name": "SHDN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Shutdown pin. Active low. Pulling low enters low power shutdown mode.",
          "unused_treatment": null
        },
        "5": {
          "name": "RTN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Reference ground for all internal voltages",
          "unused_treatment": null
        },
        "6": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "System ground",
          "unused_treatment": null
        },
        "7": {
          "name": "ILIM",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "A resistor from this pin to RTN sets the overload and short-circuit current limit",
          "unused_treatment": null
        },
        "8": {
          "name": "dVdT",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "A capacitor from this pin to RTN sets output voltage slew rate",
          "unused_treatment": null
        },
        "9": {
          "name": "FLT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Fault event indicator. Open drain output.",
          "unused_treatment": "FLOAT"
        },
        "10": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Output voltage",
          "unused_treatment": null
        },
        "EP": {
          "name": "PowerPAD",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Exposed pad for heat sinking. Connect to RTN plane.",
          "unused_treatment": null
        }
      }
    }
  },
