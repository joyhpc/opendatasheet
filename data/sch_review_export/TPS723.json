  "packages": {
    "SOT-23-5 (DBV)": {
      "pin_count": 5,
      "pins": {
        "1": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground",
          "unused_treatment": null
        },
        "2": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input supply",
          "unused_treatment": null
        },
        "3": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Bipolar enable pin. Driving this pin above the positive enable threshold or below the negative enable threshold turns on the regulator.",
          "unused_treatment": null
        },
        "4": {
          "name": "NR",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Fixed voltage versions only. Connecting an external capacitor between this pin and ground bypasses noise generated by the internal band gap. (also: FB — Adjustable voltage version only. This pin is the input to the control loop error amplifier and is used to set the output voltage.)",
          "unused_treatment": null
        },
        "5": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulated output voltage. A small, 2.2-μF ceramic capacitor is needed from this pin to GND to ensure stability.",
          "unused_treatment": null
        }
      }
    },
