  "mpn": "LM5060",
  "manufacturer": "Texas Instruments",
  "category": "Other",
  "description": "High-Side Protection Controller With Low Quiescent Current",
  "packages": {
    "VSSOP-10": {
      "pin_count": 10,
      "pins": {
        "1": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Input voltage sense: a constant current sink (16 µA typical) at the SENSE pin flows through an external resistor to set the threshold for fault detection.",
          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Supply voltage input: the operating voltage range is 5.5 V to 65 V.",
          "unused_treatment": null
        },
        "3": {
          "name": "OVP",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Over-voltage protection comparator input: an external resistor divider from the system input voltage sets the Over-Voltage turn-off threshold.",
          "unused_treatment": "GND"
        },
        "4": {
          "name": "UVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Under-voltage lock-out comparator input: used as an input under-voltage lock-out by connecting this pin to a resistor divider between input supply voltage and ground.",
          "unused_treatment": "VCC"
        },
        "5": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable input: a voltage less than 0.8 V switches the device to a low current shutdown state. Includes an internal 6 µA pull-down.",
          "unused_treatment": "FLOAT"
        },
        "6": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Circuit ground",
          "unused_treatment": null
        },
        "7": {
          "name": "TIMER",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Timing capacitor: an external capacitor connected to this pin sets the VDS fault detection delay time.",
          "unused_treatment": null
        },
        "8": {
          "name": "nPGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Fault status: an open drain output. Active low indicates a fault condition.",
          "unused_treatment": null
        },
        "9": {
          "name": "OUT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense: connect to the output rail (external MOSFET source). Internally used to detect VDS and VGS conditions.",
          "unused_treatment": null
        },
        "10": {
          "name": "GATE",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Gate drive output: connect to the external MOSFET's gate. A charge-pump driven constant current source charges the GATE pin.",
          "unused_treatment": null
        }
      }
    }
  },
