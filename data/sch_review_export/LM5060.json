{
  "_schema": "sch-review-device/1.0",
  "_type": "normal_ic",
  "mpn": "LM5060",
  "manufacturer": "Texas Instruments",
  "category": "Protection",
  "description": "High-Side Protection Controller with Low Quiescent Current, 5.5V to 65V",
  "packages": {
    "VSSOP-10": {
      "pin_count": 10,
      "pins": {
        "1": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "High-side current sense input. Connect to input supply (drain of external N-FET). Internal 16µA constant current sink flows through external resistor to GND, setting VDS fault detection threshold (VSENSE - VOUT).",
          "unused_treatment": null
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Device power supply input. Operating range 5.5V to 65V. Powers internal circuitry and charge pump.",
          "unused_treatment": null
        },
        "3": {
          "name": "OVP",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Overvoltage protection comparator input. External resistor divider from input supply sets OVP turn-off threshold. Rising threshold 2.0V typ. Immediate MOSFET turn-off on OVP trip, auto-restart when OVP clears.",
          "unused_treatment": "GND"
        },
        "4": {
          "name": "UVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Undervoltage lockout comparator input. External resistor divider from input supply sets UVLO turn-on threshold. Rising threshold 1.6V typ with 180mV hysteresis. Internal 5.5µA pull-down provides hysteresis.",
          "unused_treatment": "VCC"
        },
        "5": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable input. High (>2.0V) enables controller, low (<0.8V) enters low-current shutdown (<15µA). Internal 6µA pull-down. Can serve as remote on/off or second enable for safety redundancy.",
          "unused_treatment": "PULL_DOWN"
        },
        "6": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground connection.",
          "unused_treatment": null
        },
        "7": {
          "name": "TIMER",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Fault timer capacitor pin. Single external capacitor programs three delay times: startup VGS fault delay, transition VDS fault delay, and continuous overcurrent VDS fault delay. Charged by 6µA (startup) or 11µA (post-startup), fault trips at 2.0V.",
          "unused_treatment": null
        },
        "8": {
          "name": "nPGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Active-low open-drain Power Good output. Pulled LOW when output voltage reaches input voltage and MOSFET is fully enhanced (power good). Released (high-Z) during fault, startup, or disabled state. Requires external pull-up resistor.",
          "unused_treatment": "FLOAT_OK"
        },
        "9": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Output voltage sense. Connect to source of external N-channel MOSFET (load side). Monitors VDS (SENSE-OUT) for overcurrent detection. Also serves as charge pump reference for gate drive.",
          "unused_treatment": null
        },
        "10": {
          "name": "GATE",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Gate drive output for external N-channel MOSFET. Internal charge pump drives GATE 12V typ above VIN for full enhancement. 24µA sourcing current controls output voltage slew rate. Zener clamp 16.8V between GATE and OUT.",
          "unused_treatment": null
        }
      }
    }
  },
