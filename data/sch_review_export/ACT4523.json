  "mpn": "ACT4523",
  "manufacturer": "Qorvo",
  "category": "Buck",
  "description": "Wide Input Sensorless CC/CV Step-Down DC/DC Converter",
  "packages": {
    "SOP-8EP": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "HSB",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "High Side Bias Pin. Provides power to the internal high-side MOSFET gate driver. Connect a 22nF capacitor from HSB pin to SW pin.",
          "unused_treatment": null
        },
        "2": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power Supply Input. Bypass this pin with a 10µF ceramic capacitor to GND.",
          "unused_treatment": null
        },
        "3": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Power Switching Output to External Inductor.",
          "unused_treatment": null
        },
        "4": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground. Connect this pin to a large PCB copper area for best heat dissipation.",
          "unused_treatment": null
        },
        "5": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback Input. The voltage at this pin is regulated to 0.808V. Connect to the resistor divider between output and GND.",
          "unused_treatment": null
        },
        "6": {
          "name": "COMP",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Error Amplifier Output. This pin is used to compensate the converter.",
          "unused_treatment": null
        },
        "7": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable Input. EN is pulled up to 5V with 4µA current. Drive high or leave unconnected to enable; drive low to disable.",
          "unused_treatment": "FLOAT"
        },
        "8": {
          "name": "ISET",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output Current Setting Pin. Connect a resistor from ISET to GND to program the output current.",
          "unused_treatment": null
        },
        "EP": {
          "name": "EP",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Heat Dissipation Pad. Connect this exposed pad to large ground copper area with copper and vias.",
          "unused_treatment": null
        }
      }
    }
  },
