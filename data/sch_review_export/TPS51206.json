      "pin_count": 11,
      "pins": {
        "1": {
          "name": "VDDQSNS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "VDDQ sense input, reference input for VTTREF",
          "unused_treatment": null
        },
        "2": {
          "name": "VLDOIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply input for VTT/ VTTREF",
          "unused_treatment": null
        },
        "3": {
          "name": "VTT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Power output for VTT LDO, need to connect 10-μF or greater MLCC for stability",
          "unused_treatment": null
        },
        "4": {
          "name": "PGND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power GND for VTT LDO",
          "unused_treatment": null
        },
        "5": {
          "name": "VTTSNS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "VTT LDO voltage sense input",
          "unused_treatment": null
        },
        "6": {
          "name": "VTTREF",
          "direction": "POWER_OUT",
          "signal_type": "ANALOG",
          "description": "VTTREF buffered reference output. Connect to MLCC between 0.22-μF and 1-μF for stability. The VTTREF pin can not be open.",
          "unused_treatment": null
        },
        "7": {
          "name": "S3",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "S3 signal input",
          "unused_treatment": null
        },
        "8": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Signal ground",
          "unused_treatment": null
        },
        "9": {
          "name": "S5",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "S5 signal input",
          "unused_treatment": null
        },
        "10": {
          "name": "VDD",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Device power supply input (3.3 V or 5 V)",
          "unused_treatment": null
        },
