  "description": "2A, 4.5V-21V Input, 500kHz Synchronous Step-Down Converter",
  "packages": {
    "SOT23-6": {
      "pin_count": 6,
      "pins": {
        "1": {
          "name": "BS",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Bootstrap pin for high-side gate drive. Connect a capacitor between BS and SW pins.",
          "unused_treatment": null
        },
        "2": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground connection",
          "unused_treatment": null
        },
        "3": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback input for output voltage regulation. Connect to the tap of an external resistor divider.",
          "unused_treatment": null
        },
        "4": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable control input. Drive high to turn on the device, low to turn it off.",
          "unused_treatment": null
        },
        "5": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply input voltage",
          "unused_treatment": null
        },
        "6": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Power switching node. Connect to the output inductor.",
          "unused_treatment": null
        }
      }
    }
  },
