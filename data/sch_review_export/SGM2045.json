          "unused_treatment": null
        },
        "3": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable Pin. Drive EN high to turn on the regulator. Drive EN low to turn off the regulator. The EN pin has an internal 0.03μA pull-down current source.",
          "unused_treatment": "VCC"
        },
        "4": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input Supply Voltage Pin. It is recommended to use a 1μF or larger ceramic capacitor from IN pin to ground to get good power supply decoupling.",
