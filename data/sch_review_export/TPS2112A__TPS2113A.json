        "1": {
          "name": "STAT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open-drain output that is Hi-Z if the IN2 switch is ON. STAT pulls low if the IN1 switch is ON or if OUT is Hi-Z.",
          "unused_treatment": null
        },
        "2": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Active-low enable input. TTL- and CMOS-compatible with an internal 1-µA pull-up.",
          "unused_treatment": null
        },
        "3": {
          "name": "VSNS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Voltage sense input. Connects OUT to IN1 if VSNS > 0.8 V; otherwise connects OUT to the higher of IN1 and IN2.",
          "unused_treatment": null
        },
        "4": {
          "name": "ILIM",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current limit set pin. A resistor from ILIM to GND sets the current limit.",
