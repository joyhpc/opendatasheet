  "description": "1A, Low Noise, Wide Bandwidth, High PSRR, Low Dropout Linear Regulator",
  "packages": {
    "TDFN-3×3-8CL": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulator Output Pin. It is recommended to use a ceramic capacitor (4μF to 100μF) to ensure stability.",
          "unused_treatment": null
        },
        "2": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulator Output Pin. It is recommended to use a ceramic capacitor (4μF to 100μF) to ensure stability.",
          "unused_treatment": null
        },
        "3": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback Voltage Input Pin (adjustable voltage version only). Connect to the midpoint of an external resistor divider. (also: SNS — Output Voltage Sense Input Pin (fixed voltage version only). Connect to the load side of the output trace.)",
          "unused_treatment": null
        },
        "4": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground.",
          "unused_treatment": null
        },
        "5": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable Pin. Drive EN high to turn on the regulator, low to turn off. Internal pull-down current source ensures device is off if floated.",
          "unused_treatment": "VCC"
        },
        "6": {
          "name": "NR",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Noise-Reduction Pin. Connect an external capacitor CNR to GND to reduce output noise and slow down VOUT rise.",
          "unused_treatment": null
        },
        "7": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input Supply Voltage Pin. It is recommended to use a 4.7μF or larger ceramic capacitor to ground.",
          "unused_treatment": null
        },
        "8": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input Supply Voltage Pin. It is recommended to use a 4.7μF or larger ceramic capacitor to ground.",
          "unused_treatment": null
        },
        "EP": {
          "name": "Exposed Pad",
          "direction": "PASSIVE",
          "signal_type": "NONE",
          "description": "Exposed Pad. Connect to a large ground plane to maximize thermal performance; not an electrical connection point.",
          "unused_treatment": "GND"
        }
      }
    }
  },
