  "mpn": "SGM3204",
  "manufacturer": "SGMICRO",
  "category": "Other",
  "description": "Unregulated 200mA Charge Pump Voltage Inverter",
  "packages": {
    "SOT-23-6": {
      "pin_count": 6,
      "pins": {
        "1": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Power Output with VOUT = -VIN. Bypass OUT to GND with the output filter capacitor COUT.",
          "unused_treatment": null
        },
        "2": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Supply Input. Connect to an input supply in the 1.4V to 5.5V range. Bypass IN to GND with a capacitor that has the same value as the flying capacitor.",
          "unused_treatment": null
        },
        "3": {
          "name": "CFLY-",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Negative Terminal of the Flying Capacitor CFLY.",
          "unused_treatment": null
        },
        "4": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground.",
          "unused_treatment": null
        },
        "5": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable Control. When EN = “High”, chip is in active mode. When EN = “Low”, chip is in shutdown mode.",
          "unused_treatment": null
        },
        "6": {
          "name": "CFLY+",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Positive Terminal of the Flying Capacitor CFLY.",
          "unused_treatment": null
        }
      }
    }
  },
