  "manufacturer": "Monolithic Power Systems (MPS)",
  "category": "Buck",
  "description": "High-Efficiency, 2A, 16V, 500kHz Synchronous, Step-Down Converter In a 6-Pin TSOT 23",
  "packages": {
    "TSOT-23-6": {
      "pin_count": 6,
      "pins": {
        "1": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "System Ground. Reference ground of the regulated output voltage.",
          "unused_treatment": null
        },
        "2": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch Output. Connect using a wide PCB trace.",
          "unused_treatment": null
        },
        "3": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Supply Voltage. 4.7V-to-16V input rail. Requires decoupling capacitor.",
          "unused_treatment": null
        },
        "4": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback. Connect to an external resistor divider to set the output voltage.",
          "unused_treatment": null
        },
        "5": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable. EN=HIGH to enable the device. Connect to VIN via 100kΩ resistor for auto start-up.",
          "unused_treatment": null
        },
        "6": {
          "name": "BST",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Bootstrap. Connect a capacitor between SW and BST pins to form a floating supply.",
          "unused_treatment": null
        }
      }
    }
  },
