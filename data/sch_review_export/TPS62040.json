  "description": "1.2 A/1.25 MHz, High-Efficiency Step-Down Converter",
  "packages": {
    "DGQ PACKAGE": {
      "pin_count": 11,
      "pins": {
        "1": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable. Pulling EN to ground forces the device into shutdown mode. Pulling EN to VI enables the device. EN should not be left floating and must be terminated.",
          "unused_treatment": "CUSTOM"
        },
        "2": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Supply voltage input",
