          "unused_treatment": null
        },
        "5": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback pin. Connect FB directly to the output if the fixed output voltage version is used. For the adjustable version an external resistor divider is connected to this pin.",
          "unused_treatment": null
        },
        "6": {
          "name": "MODE",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Pulling the MODE pin high allows the device to be forced into fixed frequency operation. Pulling the MODE pin to low enables the power save mode.",
          "unused_treatment": null
