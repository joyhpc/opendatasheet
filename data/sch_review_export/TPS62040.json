        },
        "5": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback pin. Connect FB directly to the output if the fixed output voltage version is used. For the adjustable version an external resistor divider is connected to this pin.",
