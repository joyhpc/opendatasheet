  "_type": "normal_ic",
  "mpn": "LM5068",
  "manufacturer": "Texas Instruments",
  "category": "Other",
  "description": "Negative Voltage Hot Swap Controller",
  "packages": {
    "VSSOP-8": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "PWRGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open Drain Power Good indicator. Active HIGH for LM5068-1/-2 and active LOW for LM5068-3/-4.",
          "unused_treatment": null
        },
        "2": {
          "name": "OV",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Line Over-Voltage Shutdown input. Sets the over-voltage shutdown level via an external resistor divider.",
          "unused_treatment": null
        },
        "3": {
          "name": "UV",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Line Under-Voltage Shutdown input. Sets the under-voltage shutdown level via an external resistor divider.",
          "unused_treatment": null
        },
        "4": {
          "name": "VEE",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Negative Supply Voltage Input",
          "unused_treatment": null
        },
        "5": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current Sense Input. Monitored via an external current sense resistor (Rs).",
          "unused_treatment": null
        },
        "6": {
          "name": "GATE",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "N-Channel MOSFET Gate Drive Output. Pulled high by an internal 60 uA current source.",
          "unused_treatment": null
        },
        "7": {
          "name": "TIMER",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Timer Input. External capacitor sets start-up delay, shutdown delay, and re-try timing.",
          "unused_treatment": null
        },
        "8": {
          "name": "VDD",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Positive Supply Voltage Input",
          "unused_treatment": null
        }
      }
    }
  },
