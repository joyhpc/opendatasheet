        },
        "3": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Return for control circuitry and low-side power MOSFET.",
          "unused_treatment": null
        },
        "4": {
          "name": "PVIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power input. Supplies the power switches of the power converter.",
          "unused_treatment": null
        },
        "5": {
          "name": "PVIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power input. Supplies the power switches of the power converter.",
          "unused_treatment": null
        },
        "6": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Supplies the control circuitry of the power converter.",
          "unused_treatment": null
        },
        "7": {
          "name": "VSENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Inverting input of the gm error amplifier.",
          "unused_treatment": null
        },
        "8": {
          "name": "COMP",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Error amplifier output, and input to the output switch current comparator. Connect frequency compensation to this pin.",
          "unused_treatment": null
        },
        "9": {
          "name": "SS/TR",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Slow start and tracking. An external capacitor connected to this pin sets the internal voltage reference rise time. The voltage on this pin overrides the internal reference. It can be used for tracking and sequencing.",
          "unused_treatment": null
        },
        "10": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable pin. Float to enable. Adjust the input undervoltage lockout with two resistors.",
          "unused_treatment": "FLOAT"
        },
        "11": {
          "name": "PH",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "The switch node.",
          "unused_treatment": null
        },
        "12": {
          "name": "PH",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "The switch node.",
          "unused_treatment": null
        },
        "13": {
          "name": "BOOT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "A bootstrap cap is required between BOOT and PH. The voltage on this cap carries the gate drive voltage for the high-side MOSFET.",
          "unused_treatment": null
        },
        "14": {
          "name": "PWRGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Power Good fault pin. Asserts low if output voltage is low due to thermal shutdown, dropout, overvoltage, EN shutdown or during slow start.",
          "unused_treatment": null
        },
        "15": {
          "name": "Exposed Thermal PAD",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Thermal pad of the package and signal ground and it must be soldered down for proper operation.",
          "unused_treatment": null
        }
