  "description": "Negative Voltage System Power Management and Protection IC with PMBus",
  "packages": {
    "HTSSOP-28": {
      "pin_count": 29,
      "pins": {
        "1": {
          "name": "VCC",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Positive supply input. Connect the VCC pin to the positive voltage rail.",
          "unused_treatment": null
        },
        "2": {
          "name": "VAUXH",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "High voltage auxiliary input. VCC with respect to VEE is measured by connecting the VAUXH pin to the VCC rail.",
          "unused_treatment": null
        },
        "3": {
          "name": "NC",
          "direction": "NC",
          "signal_type": "NONE",
          "description": "No connect. This pin is not internally connected and should not be connected to any signal or power rail.",
          "unused_treatment": "FLOAT"
        },
        "27": {
          "name": "NC",
          "direction": "NC",
          "signal_type": "NONE",
          "description": "No connect. This pin is not internally connected and should not be connected to any signal or power rail.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "GATE",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "MOSFET gate control signal for fault control of the output. The GATE pin is clamped to VEE through a 12.6V internal zener diode.",
          "unused_treatment": null
        },
        "5": {
          "name": "UVLO/EN",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Under-voltage lockout threshold input. Connecting the UVLO pin to a resistor divider from VCC to VEE will set the under-voltage lockout threshold.",
          "unused_treatment": null
        },
        "6": {
          "name": "OVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Over-voltage lockout threshold input. Connecting the OVLO pin to a resistor divider from VCC to VEE will set the over-voltage lockout threshold.",
          "unused_treatment": null
        },
        "7": {
          "name": "SENSE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current limit and power limit sense input. SENSE provides a direct connection to the MOSFET source and current sense resistor voltage.",
          "unused_treatment": null
        },
        "8": {
          "name": "SENSE_K",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current telemetry Kelvin sense positive input. SENSE_K is the positive input to a precision differential current sense amplifier.",
          "unused_treatment": null
        },
        "9": {
          "name": "VEE_K",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current telemetry Kelvin sense negative input. The VEE_K pin is the negative input to a precision differential current sense amplifier.",
          "unused_treatment": null
        },
        "10": {
          "name": "VEE",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Negative supply input. Connect the VEE pin to the negative voltage supply rail.",
          "unused_treatment": null
        },
        "11": {
          "name": "SDAI",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "SMBus data input. The SDAI pin is designed to read PMBus commands using the SMBus communication protocol.",
          "unused_treatment": null
        },
        "12": {
          "name": "SDAO",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "SMBus data output. The SDAO pin is designed to transmit PMBus commands using the SMBus communication protocol.",
          "unused_treatment": null
        },
        "13": {
          "name": "SCL",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "SMBus clock input.",
          "unused_treatment": null
        },
        "14": {
          "name": "SMBA",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "SMBus alert. Open drain MOSFET which pulls the pin to VEE if a fault is detected.",
          "unused_treatment": null
        },
        "15": {
          "name": "VREF",
          "direction": "POWER_OUT",
          "signal_type": "ANALOG",
          "description": "Internal ADC reference output. Connect a 1 µF capacitor from the VREF pin to VEE.",
          "unused_treatment": null
        },
        "16": {
          "name": "DIODE",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Positive diode sense. Connected to the anode of an external diode for temperature monitoring.",
          "unused_treatment": null
        },
        "17": {
          "name": "VAUX",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Auxiliary pin allows voltage telemetry from an external source. Full scale input of 2.97V.",
          "unused_treatment": null
        },
        "18": {
          "name": "ADR2",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Address pin 2. Can be connected to VDD, VEE, or left open to set the PMBus address.",
          "unused_treatment": "FLOAT"
        },
        "19": {
          "name": "ADR1",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Address pin 1. Can be connected to VDD, VEE, or left open to set the PMBus address.",
          "unused_treatment": "FLOAT"
        },
        "20": {
          "name": "ADR0",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Address pin 0. Can be connected to VDD, VEE, or left open to set the PMBus address.",
          "unused_treatment": "FLOAT"
        },
        "21": {
          "name": "VDD",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Internal 4.9V sub-regulator output. Connect to VEE through a 1 µF ceramic bypass capacitor.",
          "unused_treatment": null
        },
        "22": {
          "name": "CL",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current limit threshold input. Set to 26 mV by connecting to VDD and 50 mV when connected to VEE.",
          "unused_treatment": null
        },
        "23": {
          "name": "RETRY",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Retry selection pin. Connect to VDD for lockout or VEE for retry after a fault.",
          "unused_treatment": null
        },
        "24": {
          "name": "TIMER",
          "direction": "PASSIVE",
          "signal_type": "ANALOG",
          "description": "Timing input. Set insertion time delay and fault timeout period by connecting a capacitor to VEE.",
          "unused_treatment": null
        },
        "25": {
          "name": "PWR",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Power limit input. Connecting a resistor from PWR to VEE sets the maximum power dissipation allowed in the external MOSFET.",
          "unused_treatment": null
        },
        "26": {
          "name": "OUT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense input. Used to sense output voltage and calculate power across the MOSFET.",
          "unused_treatment": null
        },
        "28": {
          "name": "PGD",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Power good monitor output. Open-drain output pulls low during over-current, UVLO, and OVLO.",
          "unused_treatment": null
        },
        "EP": {
          "name": "EP",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Exposed pad. Connect to PCB VEE plane using multiple thermal vias.",
          "unused_treatment": null
        }
      }
    }
  },
