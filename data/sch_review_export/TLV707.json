  "mpn": "TLV707",
  "manufacturer": "Texas Instruments",
  "category": "LDO",
  "description": "200mA, Low IQ, Low Noise, Low Dropout Linear Regulator",
  "packages": {
    "X2SON-4": {
      "pin_count": 5,
      "pins": {
        "1": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Regulated output voltage pin. A small 1-µF ceramic capacitor is required from this pin to ground to assure stability.",
          "unused_treatment": null
        },
        "2": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground pin",
          "unused_treatment": null
        },
        "3": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable pin. Driving EN over 0.9 V turns on the regulator. Driving EN below 0.4 V puts the regulator into shutdown mode. For TLV707P, output voltage is discharged through an internal 120-Ω resistor when device is shut down.",
          "unused_treatment": null
        },
        "4": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input pin. For good transient performance, place a small 1-µF ceramic capacitor from this pin to ground.",
          "unused_treatment": null
        },
        "EP": {
          "name": "Thermal Pad",
          "direction": "PASSIVE",
          "signal_type": "NONE",
          "description": "Thermal pad for heat dissipation.",
          "unused_treatment": null
        }
      }
    }
  },
