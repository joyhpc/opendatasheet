{
  "_schema": "device-knowledge/2.0",
  "_type": "normal_ic",
  "_layers": [
    "L0_skeleton",
    "L1_electrical"
  ],
  "mpn": "TPS56637",
  "manufacturer": "Texas Instruments",
  "category": "Buck",
  "description": "4.5V to 28V Input, 6A Synchronous Buck Converter",
  "packages": {
    "VQFN-HR (10)": {
      "pin_count": 10,
      "pins": {
        "1": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Enable input control. Driving EN high or leaving this pin floating enables the converter. A resistor divider can be used to imply an UVLO function.",
          "unused_treatment": "FLOAT"
        },
        "2": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output feedback. Connect FB to the tap of an external resistor divider from the output to GND to set the output voltage.",
          "unused_treatment": null
        },
        "3": {
          "name": "AGND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground of internal analog circuitry. Connect AGND to PGND plane at a single point.",
          "unused_treatment": null
        },
        "4": {
          "name": "PG",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open Drain Power Good Indicator, it is asserted low if output voltage is out of PG threshold due to over-voltage, under-voltage, thermal shutdown, EN shutdown or during soft-start.",
          "unused_treatment": null
        },
        "5": {
          "name": "NC",
          "direction": "NC",
          "signal_type": "NONE",
          "description": "Not Connected, keep this pin floating.",
          "unused_treatment": "FLOAT"
        },
        "6": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switching node terminal. Connect the output inductor to this pin with wide and short tracks",
          "unused_treatment": null
        },
        "7": {
          "name": "BOOT",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Supply input for the gate drive voltage of the high-side MOSFET. Connect a 0.1-μF bootstrap capacitor between BOOT and SW.",
          "unused_treatment": null
        },
        "8": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input voltage supply pin. Drain terminal of high-side MOSFET. Connect the input decoupling capacitors between VIN and GND.",
          "unused_treatment": null
        },
        "9": {
          "name": "PGND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power GND terminal. Source terminal of low side MOSFET.",
          "unused_treatment": null
        },
        "10": {
          "name": "MODE",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Operation mode selection pin. Leaving this pin floating(≥500 kΩ) forces the TPS56637 into FCCM. Connecting this pin to GND(≤10 kΩ) forces the TPS56637 into Eco-mode™ under light load.",
          "unused_treatment": "FLOAT"
        }
      }
    }
  },
