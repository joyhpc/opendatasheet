  "mpn": "TPS2114",
  "manufacturer": "Texas Instruments",
  "category": "Switch",
  "description": "Two-Input, One-Output Power Multiplexer With Low rDS(on) Switches",
  "packages": {
    "TSSOP-8": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "STAT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open-drain output; Hi-Z if IN2 switch is ON, pulls low if IN1 switch is ON or if OUT is Hi-Z.",
          "unused_treatment": null
        },
        "2": {
          "name": "D0",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "TTL and CMOS compatible input pin with internal 1-µA pullup resistor.",
          "unused_treatment": "FLOAT"
        },
        "3": {
          "name": "D1",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "TTL and CMOS compatible input pin with internal 1-µA pullup resistor.",
          "unused_treatment": "FLOAT"
        },
        "4": {
          "name": "ILIM",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Current limit programming pin; a resistor to GND sets the current limit.",
          "unused_treatment": null
        },
        "5": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground",
          "unused_treatment": null
        },
        "6": {
          "name": "IN2",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Secondary power switch input.",
          "unused_treatment": null
        },
        "7": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Power switch output",
          "unused_treatment": null
        },
        "8": {
          "name": "IN1",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Primary power switch input.",
          "unused_treatment": null
        }
      }
    }
  },
