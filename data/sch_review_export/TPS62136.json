{
  "_schema": "sch-review-device/1.1",
  "_type": "normal_ic",
  "_layers": [
    "L0_skeleton",
    "L1_electrical"
  ],
  "mpn": "TPS62136",
  "manufacturer": "Texas Instruments",
  "category": "Buck",
  "description": "1-MHz High Accuracy 3-V to 17-V 4-A Step-Down Converters with DCS Control",
  "packages": {
    "VQFN-11 (RGX)": {
      "pin_count": 11,
      "pins": {
        "1": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply input. Make sure the input capacitor is connected as close as possible between pin VIN and GND.",
          "unused_treatment": null
        },
        "2": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "This is the switch pin of the converter and is connected to the internal Power MOSFETs.",
          "unused_treatment": null
        },
        "3": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground pin.",
          "unused_treatment": null
        },
        "4": {
          "name": "FB2",
          "direction": "OUTPUT",
          "signal_type": "ANALOG",
          "description": "Open drain of an internal switch to GND. Allows to turn on a resistor in parallel to the feedback resistor R2 and increase the output voltage with VSEL = high.",
          "unused_treatment": null
        },
        "5": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Voltage feedback input, connect resistive output voltage divider to this pin.",
          "unused_treatment": null
        },
        "6": {
          "name": "VOS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense pin. Connect directly to the positive pin of the output capacitor.",
          "unused_treatment": null
        },
        "7": {
          "name": "PG",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Open drain power good output.",
          "unused_treatment": null
        },
        "8": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "This is the enable pin of the device. Connect to logic low to disable the device. Pull high to enable the device. Do not leave this pin unconnected.",
          "unused_treatment": null
        },
        "9": {
          "name": "SS/TR",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Soft-Start / Tracking pin. An external capacitor connected from this pin to GND defines the rise time for the internal reference voltage. The pin can also be used as an input for tracking and sequencing.",
          "unused_treatment": null
        },
        "10": {
          "name": "MODE",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "The device runs in PFM/PWM mode when this pin is pulled low. When the pin is pulled high, the device runs in forced PWM mode. Do not leave this pin unconnected.",
          "unused_treatment": null
        },
        "11": {
          "name": "VSEL",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Voltage scaling control input. Turns on an internal switch from FB2 to GND when this pin is set high.",
          "unused_treatment": null
        }
      }
    }
  },
