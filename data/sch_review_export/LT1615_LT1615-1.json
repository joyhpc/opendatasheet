  "description": "Micropower Step-Up DC/DC Converter in SOT-23",
  "packages": {
    "SOT-23-5": {
      "pin_count": 5,
      "pins": {
        "1": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch Pin. Collector of the internal NPN power transistor. Connect to inductor and Schottky diode.",
          "unused_treatment": null
        },
        "2": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground Pin. Connect directly to local ground plane.",
          "unused_treatment": null
        },
        "3": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback Pin. Reference voltage is 1.23V. Connect resistive divider tap here to set output voltage.",
          "unused_treatment": null
        },
        "4": {
          "name": "SHDN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Shutdown Pin. Logic low puts the device in shutdown mode. Tie to 0.9V or higher to enable.",
          "unused_treatment": null
        },
        "5": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input Supply Pin. Must be locally bypassed with a capacitor.",
          "unused_treatment": null
        }
      }
    }
  },
