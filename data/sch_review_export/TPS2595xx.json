  "mpn": "TPS2595xx",
  "manufacturer": "Texas Instruments",
  "category": "Other",
  "description": "2.7 V to 18 V, 4-A, 34-mΩ eFuse With Fast Overvoltage Protection",
  "packages": {
    "WSON-8": {
      "pin_count": 9,
      "pins": {
        "1": {
          "name": "dVdt",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Output turn-on slew rate control. A capacitor from this pin to GND sets the slew rate. Leave floating for fastest turn-on.",
          "unused_treatment": "FLOAT"
        },
        "2": {
          "name": "EN/UVLO",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Active high enable and undervoltage lockout input for TPS2595x0, TPS2595x1, and TPS2595x5 variants. (also: EN_BAR/OVLO — Active low enable and overvoltage lockout input for TPS2595x3 variants.)",
          "unused_treatment": null
        },
        "3": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply input.",
          "unused_treatment": null
        },
        "4": {
          "name": "IN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Power supply input.",
          "unused_treatment": null
        },
        "5": {
          "name": "OUT",
          "direction": "POWER_OUT",
          "signal_type": "POWER",
          "description": "Power output.",
          "unused_treatment": null
        },
        "6": {
          "name": "FLT",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Fault event indicator (active low, open-drain) for TPS2595x0, TPS2595x1, and TPS2595x3 variants. Requires external pull-up. (also: QOD — Quick Output Discharge pin for TPS2595x5 variants. Tied to OUT directly or through an external resistor.)",
          "unused_treatment": null
        },
        "7": {
          "name": "ILM",
          "direction": "BIDIRECTIONAL",
          "signal_type": "ANALOG",
          "description": "Current limit set and monitor pin. External resistor to GND sets the limit; pin voltage monitors load current.",
          "unused_treatment": null
        },
        "8": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground.",
          "unused_treatment": null
        },
        "EP": {
          "name": "PAD",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Exposed thermal pad; must be connected to GND for heat dissipation.",
          "unused_treatment": "GND"
        }
      }
    }
  },
