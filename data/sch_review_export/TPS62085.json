        },
        "2": {
          "name": "PG",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Power good open drain output pin. The pullup resistor can not be connected to any voltage higher than 6 V. If unused, leave it floating.",
          "unused_treatment": "FLOAT"
        },
        "3": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback pin. For the fixed output voltage versions this pin must be connected to the output voltage.",
          "unused_treatment": null
        },
        "4": {
          "name": "VOS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense pin. This pin must be directly connected to the output capacitor.",
