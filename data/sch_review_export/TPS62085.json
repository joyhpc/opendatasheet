  "description": "3A Step-Down Converter with DCS-Control in 2mm x 2mm VSON Package",
  "packages": {
    "VSON-7": {
      "pin_count": 8,
      "pins": {
        "1": {
          "name": "EN",
          "direction": "INPUT",
          "signal_type": "DIGITAL",
          "description": "Device enable pin. To enable the device, this pin needs to be pulled high. Pulling this pin low disables the device. This pin has a pulldown resistor of typically 400 kΩ when the device is disabled.",
          "unused_treatment": null
        },
        "2": {
          "name": "PG",
          "direction": "OUTPUT",
          "signal_type": "DIGITAL",
          "description": "Power good open drain output pin. The pullup resistor can not be connected to any voltage higher than 6 V. If unused, leave it floating.",
          "unused_treatment": "FLOAT"
        },
        "3": {
          "name": "FB",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Feedback pin. For the fixed output voltage versions this pin must be connected to the output voltage.",
          "unused_treatment": null
        },
        "4": {
          "name": "VOS",
          "direction": "INPUT",
          "signal_type": "ANALOG",
          "description": "Output voltage sense pin. This pin must be directly connected to the output capacitor.",
          "unused_treatment": null
        },
        "5": {
          "name": "GND",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Ground pin.",
          "unused_treatment": null
        },
        "6": {
          "name": "SW",
          "direction": "OUTPUT",
          "signal_type": "POWER",
          "description": "Switch pin of the power stage.",
          "unused_treatment": null
        },
        "7": {
          "name": "VIN",
          "direction": "POWER_IN",
          "signal_type": "POWER",
          "description": "Input voltage pin.",
          "unused_treatment": null
        },
        "EP": {
          "name": "Thermal Pad",
          "direction": "PASSIVE",
          "signal_type": "POWER",
          "description": "Exposed thermal pad for heat dissipation. Typically connected to ground.",
          "unused_treatment": null
        }
      }
    }
  },
