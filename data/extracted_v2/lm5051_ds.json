    "pin_definitions": [
      {
        "pin_number": 1,
        "pin_name": "LINE",
        "type": "Power",
        "description": "Power supply pin to bias the internal 12V zener shunt regulator at the VCC pin through an internal 50 kΩ (typical) series resistor."
      },
      {
        "pin_number": 2,
        "pin_name": "VCC",
        "type": "Power",
        "description": "Connection to the internal 12V zener shunt voltage regulator. Bypass this pin with minimum 0.1µF capacitor to the VSS pin."
      },
      {
        "pin_number": 3,
        "pin_name": "OFF",
        "type": "Input",
        "description": "FET Test Mode control input. Logic low or open state will deactivate the FET Test Mode and allow normal operation. A logic high state will pull the GATE pin low and turn off the external MOSFET."
      },
      {
        "pin_number": 4,
        "pin_name": "nFGD",
        "type": "Output",
        "description": "Open drain output for the FET Test circuit. An active low state indicates that the forward voltage of the external MOSFET is greater than 260 mV typical."
      },
      {
        "pin_number": 5,
        "pin_name": "INP/VSS",
        "type": "Power",
        "description": "Internally connected to device Pin 7."
      },
      {
        "pin_number": 6,
        "pin_name": "INN",
        "type": "Input",
        "description": "Voltage sense connection to the external MOSFET Drain pin."
      },
      {
        "pin_number": 7,
        "pin_name": "INP/VSS",
        "type": "Power",
        "description": "Negative supply voltage connection and MOSFET voltage sense connected to the external MOSFET common source connection."
      },
      {
        "pin_number": 8,
        "pin_name": "GATE",
        "type": "Output",
        "description": "Connection to the external MOSFET Gate."
      }
    ]
  },
