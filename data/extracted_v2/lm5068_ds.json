    "pin_definitions": [
      {
        "pin_number": 1,
        "pin_name": "PWRGD",
        "type": "Output",
        "description": "Open Drain Power Good indicator. Active HIGH for -1/-2, active LOW for -3/-4."
      },
      {
        "pin_number": 2,
        "pin_name": "OV",
        "type": "Input",
        "description": "Line Over-Voltage Shutdown. Sets the over-voltage shutdown level via external resistor divider."
      },
      {
        "pin_number": 3,
        "pin_name": "UV",
        "type": "Input",
        "description": "Line Under-Voltage Shutdown. Sets the under-voltage shutdown level via external resistor divider."
      },
      {
        "pin_number": 4,
        "pin_name": "VEE",
        "type": "Power",
        "description": "Negative Supply Voltage Input."
      },
      {
        "pin_number": 5,
        "pin_name": "SENSE",
        "type": "Input",
        "description": "Current Sense Input. Monitored via external current sense resistor (RS)."
      },
      {
        "pin_number": 6,
        "pin_name": "GATE",
        "type": "Output",
        "description": "N-Channel MOSFET Gate Drive Output. Pulled high by a 60 µA current source."
      },
      {
        "pin_number": 7,
        "pin_name": "TIMER",
        "type": "Input/Output",
        "description": "Timer Input. External capacitor sets initial start-up delay and delay to shutdown during over-current."
      },
      {
        "pin_number": 8,
        "pin_name": "VDD",
        "type": "Power",
        "description": "Positive Supply Voltage Input."
      }
    ]
  },
