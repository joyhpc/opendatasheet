    "pin_definitions": [
      {
        "pin_number": 1,
        "pin_name": "EN",
        "type": "Input",
        "description": "Enable. Pulling EN to ground forces the device into shutdown mode. Pulling EN to VI enables the device. EN should not be left floating and must be terminated."
      },
      {
        "pin_number": "2, 3",
        "pin_name": "VIN",
        "type": "Input",
        "description": "Supply voltage input"
      },
      {
        "pin_number": 4,
        "pin_name": "GND",
        "type": "Power",
        "description": "Analog ground"
      },
      {
        "pin_number": 5,
        "pin_name": "FB",
        "type": "Input",
        "description": "Feedback pin. Connect FB directly to the output if the fixed output voltage version is used. For the adjustable version an external resistor divider is connected to this pin. The internal voltage divider is disabled for the adjustable version."
      },
      {
        "pin_number": 6,
        "pin_name": "MODE",
        "type": "Input",
        "description": "Pulling the MODE pin high allows the device to be forced into fixed frequency operation. Pulling the MODE pin to low enables the power save mode where the device operates in fixed frequency PWM mode at high load currents and in PFM mode (pulse frequency modulation) at light load currents."
      },
      {
        "pin_number": "7, 8",
        "pin_name": "SW",
        "type": "I/O",
        "description": "This is the switch pin of the converter and is connected to the drain of the internal power MOSFETs."
      },
      {
        "pin_number": "9, 10",
        "pin_name": "PGND",
        "type": "Power",
        "description": "Power ground"
      }
    ]
  },
