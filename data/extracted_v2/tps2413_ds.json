    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "VDD",
        "type": "PWR",
        "description": "Input power for the gate drive charge pump and internal controls. VDD must be connected to a supply voltage >= 3 V."
      },
      {
        "pin_number": "2",
        "pin_name": "RSET",
        "type": "I",
        "description": "Connect a resistor to ground to program the turnoff threshold. Leaving RSET open results in a slightly positive V(A-C) turnoff threshold."
      },
      {
        "pin_number": "3",
        "pin_name": "RSVD",
        "type": "PWR",
        "description": "This pin must be connected to GND."
      },
      {
        "pin_number": "4",
        "pin_name": "GND",
        "type": "PWR",
        "description": "Device ground."
      },
      {
        "pin_number": "5",
        "pin_name": "GATE",
        "type": "O",
        "description": "Connect to the gate of the external MOSFET. Controls the MOSFET to emulate a low forward-voltage diode."
      },
      {
        "pin_number": "6",
        "pin_name": "C",
        "type": "I",
        "description": "Voltage sense input that connects to the simulated diode cathode. Connect to the MOSFET drain in the typical configuration."
      },
      {
        "pin_number": "7",
        "pin_name": "A",
        "type": "I",
        "description": "Voltage sense input that connects to the simulated diode anode. It also serves as the reference for the charge-pump bias supply on BYP. Connect to the MOSFET source in the typical configuration."
      },
      {
        "pin_number": "8",
        "pin_name": "BYP",
        "type": "I/O",
        "description": "Connect a storage capacitor from BYP to A to filter the gate drive supply voltage."
      }
    ]
  },
