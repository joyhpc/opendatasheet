    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "GND",
        "type": "Power",
        "description": "Ground Pin. Care must be taken in layout. This pin should be placed outside of the Schottky Diode to output capacitor ground path to prevent switching current spikes from inducing voltage noise into XL4003."
      },
      {
        "pin_number": "2",
        "pin_name": "FB",
        "type": "Input",
        "description": "Feedback Pin (FB). Through an external resistor divider network, FB senses the output voltage and regulates it. The feedback threshold voltage is 0.8V."
      },
      {
        "pin_number": "3",
        "pin_name": "SW",
        "type": "Output",
        "description": "Power Switch Output Pin (SW). SW is the switch node that supplies power to the output."
      },
      {
        "pin_number": "4",
        "pin_name": "EN",
        "type": "Input",
        "description": "Enable Pin. Drive EN pin high to turn on the device, drive it low to turn it off."
      },
      {
        "pin_number": "5",
        "pin_name": "VIN",
        "type": "Power",
        "description": "Supply Voltage Input Pin. XL4003 operates from a 5V to 32V DC voltage. Bypass Vin to GND with a suitably large capacitor to eliminate noise on the input."
      },
      {
        "pin_number": "Tab",
        "pin_name": "SW",
        "type": "Output",
        "description": "Metal Tab is connected to SW pin."
      }
