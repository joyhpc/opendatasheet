    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "AGND",
        "type": "Ground",
        "description": "Ground of internal analog circuitry. AGND must be connected to PGND for proper operation."
      },
      {
        "pin_number": "2, 3, 16, 17",
        "pin_name": "VIN",
        "type": "Input",
        "description": "Input voltage supply pin. Power for the internal circuit and the connection to drain of high-side MOSFET."
      },
      {
        "pin_number": "4, 5, 6, 7, 12, 13, 14, 15",
        "pin_name": "PGND",
        "type": "Ground",
        "description": "Ground return for low-side power MOSFET and its drivers."
      },
      {
        "pin_number": "8, 9, 10, 11",
        "pin_name": "SW",
        "type": "Output",
        "description": "Switching node. Connected to the source of the high-side MOSFET and drain of the low-side MOSFET."
      },
      {
        "pin_number": "18",
        "pin_name": "BOOT",
        "type": "Input",
        "description": "Floating supply voltage for high-side MOSFET gate drive circuit. Connect a 0.1-µF ceramic capacitor between BOOT and SW pins."
      },
      {
        "pin_number": "19",
        "pin_name": "PGOOD",
        "type": "Output",
        "description": "Open-drain power good indicator. It is asserted low if output voltage is outside if the PGOOD thresholds, VIN is low, EN is low, device is in thermal shutdown or device is in soft start."
      },
      {
        "pin_number": "20",
        "pin_name": "EN",
        "type": "Input",
        "description": "Enable pin. Float or pull high to enable the device. Connect a resistor divider to this pin to implement adjustable under voltage lockout and hysteresis."
      },
      {
        "pin_number": "21",
        "pin_name": "SS/TRK",
        "type": "Input",
        "description": "Soft-start and tracking pin. Connecting an external capacitor sets the soft-start time. This pin can also be used for tracking and sequencing."
      },
      {
        "pin_number": "22",
        "pin_name": "COMP",
        "type": "Input",
        "description": "Error amplifier output and input to the PWM modulator. Connect loop compensation to this pin."
      },
      {
        "pin_number": "23",
        "pin_name": "FB",
        "type": "Input",
        "description": "Converter feedback input. Connect to the output voltage with a resistor divider."
      },
      {
        "pin_number": "24",
        "pin_name": "RT/CLK",
        "type": "Input",
        "description": "Switching frequency setting pin. In RT mode, an external timing resistor adjusts the switching frequency. In CLK mode, the device synchronizes to an external clock input to this pin."
      },
      {
        "pin_number": "Thermal PAD",
        "pin_name": "Thermal PAD",
        "type": "Ground",
        "description": "Exposed thermal pad. Connect to PGND pins and to internal ground planes using multiple vias for good thermal performance."
      }
    ]
  },
