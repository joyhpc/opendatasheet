    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "dVdt",
        "type": "Analog I/O",
        "description": "A capacitor from this pin to GND sets the output turn on slew rate. Leave this pin floating for the fastest turn on slew rate."
      },
      {
        "pin_number": "2",
        "pin_name": "EN/UVLO or EN/OVLO",
        "type": "Analog input",
        "description": "Active high enable for TPS2595x0, TPS2595x1, TPS2595x5. Active low enable for TPS2595x3. Used to adjust UVLO/OVLO threshold."
      },
      {
        "pin_number": "3,4",
        "pin_name": "IN",
        "type": "Power",
        "description": "Power input"
      },
      {
        "pin_number": "5",
        "pin_name": "OUT",
        "type": "Power",
        "description": "Power output"
      },
      {
        "pin_number": "6",
        "pin_name": "FLT or QOD",
        "type": "Digital output",
        "description": "Fault event indicator (FLT) or Quick Output Discharge Pin (QOD) depending on variant."
      },
      {
        "pin_number": "7",
        "pin_name": "ILM",
        "type": "Analog I/O",
        "description": "Dual function pin used to limit and monitor the output current. An external resistor sets the limit."
      },
      {
        "pin_number": "8",
        "pin_name": "GND",
        "type": "Ground",
        "description": "Ground"
      },
      {
        "pin_number": "PAD",
        "pin_name": "GND",
        "type": "Thermal/Ground",
        "description": "The exposed pad is used primarily for heat dissipation and must be connected to GND."
      }
    ]
  },
