    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "GND",
        "type": "Ground",
        "description": "Ground"
      },
      {
        "pin_number": "2",
        "pin_name": "dVdt",
        "type": "Analog Output",
        "description": "A capacitor from this pin to GND sets the output turn on slew rate. Leave this pin floating for the fastest turn on slew rate."
      },
      {
        "pin_number": "3",
        "pin_name": "EN/UVLO",
        "type": "Analog Input",
        "description": "Active High Enable for the Device. A resistor divider can be used to adjust the Undervoltage Lockout threshold. Do not leave floating."
      },
      {
        "pin_number": "4",
        "pin_name": "IN",
        "type": "Power",
        "description": "Power Input"
      },
      {
        "pin_number": "5",
        "pin_name": "OUT",
        "type": "Power",
        "description": "Power Output"
      },
      {
        "pin_number": "6",
        "pin_name": "FLT",
        "type": "Digital Output",
        "description": "Active Low indicator which will be pulled low when a fault is detected. It is an open-drain output that requires an external pull-up resistance."
      },
      {
        "pin_number": "7",
        "pin_name": "ILM",
        "type": "Analog Output",
        "description": "This is a dual function pin used to limit and monitor the output current. An external resistor from this pin to GND sets the output current limit. The pin voltage can also be used to monitor the output load current."
      },
      {
        "pin_number": "8",
        "pin_name": "OVLO/OVCSEL",
        "type": "Analog Input",
        "description": "TPS25963x: A resistor divider can be used to adjust the Overvoltage Lockout threshold. Do not leave floating. TPS25962x: Overvoltage Clamp level select pin. Refer to Overvoltage Clamp for more details."
      },
      {
        "pin_number": "Thermal pad",
        "pin_name": "Thermal pad",
        "type": "Ground",
        "description": "The Exposed Pad is used primarily for heat dissipation and must be connected to system ground plane for best thermal performance."
      }
    ]
  },
