    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "STAT",
        "type": "O",
        "description": "STAT is an open-drain output that is Hi-Z if the IN2 switch is ON. STAT pulls low if the IN1 switch is ON or if OUT is Hi-Z (that is, EN is equal to logic '0')"
      },
      {
        "pin_number": "2",
        "pin_name": "EN",
        "type": "I",
        "description": "TTL- and CMOS-compatible input with a 1-μA pull-up. The Truth Table illustrates the functionality of EN."
      },
      {
        "pin_number": "3",
        "pin_name": "VSNS",
        "type": "I",
        "description": "An internal power FET connects OUT to IN1 if the VSNS voltage is greater than 0.8 V. Otherwise, the FET connects OUT to the higher of IN1 and IN2. The Truth Table illustrates the functionality of VSNS."
      },
      {
        "pin_number": "4",
        "pin_name": "ILIM",
        "type": "I",
        "description": "A resistor (RILIM) from ILIM to GND sets the current limit (IL) to 250/RILIM and 500/RILIM for the TPS2112A and TPS2113A, respectively."
      },
      {
        "pin_number": "5",
        "pin_name": "GND",
        "type": "Power",
        "description": "Ground"
      },
      {
        "pin_number": "6",
        "pin_name": "IN2",
        "type": "I",
        "description": "Secondary power switch input. The IN2 switch can be enabled only if the IN2 supply is above the UVLO threshold and at least one supply exceeds the internal VDD UVLO."
      },
      {
        "pin_number": "7",
        "pin_name": "OUT",
        "type": "O",
        "description": "Power switch output"
      },
      {
        "pin_number": "8",
        "pin_name": "IN1",
        "type": "I",
        "description": "Primary power switch input. The IN1 switch can be enabled only if the IN1 supply is above the UVLO threshold and at least one supply exceeds the internal VDD UVLO."
      },
      {
        "pin_number": "Pad",
        "pin_name": "Pad",
        "type": "Power",
        "description": "DRB package only. Connect to GND. Must be connected to large copper area in order to meet stated package dissipation ratings."
      }
    ]
  },
