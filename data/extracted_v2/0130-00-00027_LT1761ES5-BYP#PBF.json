      {
        "pin_number": 1,
        "pin_name": "IN",
        "type": "Power Input",
        "description": "Input. Power is supplied to the device through the IN pin. A bypass capacitor is required if the device is more than six inches away from the main input filter capacitor."
      },
      {
        "pin_number": 2,
        "pin_name": "GND",
        "type": "Ground",
        "description": "Ground."
      },
      {
        "pin_number": 3,
        "pin_name": "BYP / SHDN",
        "type": "Input",
        "description": "Bypass (on LT1761-BYP) or Shutdown (on LT1761-SD and LT1761-X). SHDN pin is used to put the regulator into a low power shutdown state."
      },
      {
        "pin_number": 4,
        "pin_name": "ADJ / BYP",
        "type": "Input",
        "description": "Adjust Pin (on LT1761-BYP and LT1761-SD) or Bypass (on LT1761-X). ADJ pin is the input to the error amplifier."
      },
      {
        "pin_number": 5,
        "pin_name": "OUT",
        "type": "Power Output",
        "description": "Output. The output supplies power to the load. A minimum output capacitor of 1µF is required to prevent oscillations."
      }
    ]
