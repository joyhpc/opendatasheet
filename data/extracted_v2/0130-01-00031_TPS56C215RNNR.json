    "pin_definitions": [
      {
        "pin_number": "1",
        "pin_name": "BOOT",
        "type": "I",
        "description": "Supply input for the gate drive voltage of the high-side MOSFET. Connect the bootstrap capacitor between BOOT and SW."
      },
      {
        "pin_number": "2, 11",
        "pin_name": "VIN",
        "type": "P",
        "description": "Input voltage supply pin for the control circuitry. Connect the input decoupling capacitors between VIN and PGND."
      },
      {
        "pin_number": "3, 4, 5, 8, 9, 10",
        "pin_name": "PGND",
        "type": "G",
        "description": "Power GND terminal for the controller circuit and the internal circuitry. Connect to AGND with a short trace."
      },
      {
        "pin_number": "6, 7",
        "pin_name": "SW",
        "type": "O",
        "description": "Switch node terminal. Connect the output inductor to this pin."
      },
      {
        "pin_number": "12",
        "pin_name": "AGND",
        "type": "G",
        "description": "Ground of internal analog circuitry. Connect AGND to PGND plane with a short trace."
      },
      {
        "pin_number": "13",
        "pin_name": "FB",
        "type": "I",
        "description": "Converter feedback input. Connect to the center tap of the resistor divider between output voltage and AGND."
      },
      {
        "pin_number": "14",
        "pin_name": "SS",
        "type": "O",
        "description": "Soft-Start time selection pin. Connecting an external capacitor sets the soft-start time and if no external capacitor is connected, the converter starts up in 1 ms."
      },
      {
        "pin_number": "15",
        "pin_name": "EN",
        "type": "I",
        "description": "Enable input control, leaving this pin floating enables the converter. It can also be used to adjust the input UVLO by connecting to the center tap of the resistor divider between VIN and EN."
      },
      {
        "pin_number": "16",
        "pin_name": "PGOOD",
        "type": "O",
        "description": "Open-drain power good indicator, it is asserted low if output voltage is out of PGOOD threshold, overvoltage, or if the device is under thermal shutdown, EN shutdown or during soft start."
      },
      {
        "pin_number": "17",
        "pin_name": "VREG5",
        "type": "I/O",
        "description": "4.7-V internal LDO output which can also be driven externally with a 5-V input. This pin supplies voltage to the internal circuitry and gate driver. Bypass this pin with a 4.7-µF capacitor."
      },
      {
        "pin_number": "18",
        "pin_name": "MODE",
        "type": "I",
        "description": "Switching frequency, current limit selection and light load operation mode selection pin. Connect this pin to a resistor divider from VREG5 and AGND for different MODE options shown in 表 7-3."
      }
    ]
  },
