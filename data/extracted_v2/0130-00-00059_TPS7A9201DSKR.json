    "pin_definitions": [
      {
        "pin_number": "7",
        "pin_name": "EN",
        "type": "I",
        "description": "Enable pin. This pin turns the LDO on and off. If VEN ≥ VIH(EN), the regulator is enabled. If VEN ≤ VIL(EN), the regulator is disabled. The EN pin must be connected to IN if the enable function is not used."
      },
      {
        "pin_number": "3",
        "pin_name": "FB",
        "type": "I",
        "description": "Feedback pin. This pin is the input to the control loop error amplifier and is used to set the output voltage of the device."
      },
      {
        "pin_number": "4",
        "pin_name": "GND",
        "type": "—",
        "description": "Device GND. Connect to the device thermal pad."
      },
      {
        "pin_number": "9, 10",
        "pin_name": "IN",
        "type": "I",
        "description": "Input pin. A 10 µF or greater input capacitor is required."
      },
      {
        "pin_number": "8",
        "pin_name": "NR/SS",
        "type": "—",
        "description": "Noise reduction pin. Connect this pin to an external capacitor to bypass the noise generated by the internal bandgap reference. The capacitor reduces the output noise to very low levels and sets the output ramp rate to limit inrush current."
      },
      {
        "pin_number": "1, 2",
        "pin_name": "OUT",
        "type": "O",
        "description": "Regulated output. A 22 µF or greater capacitor must be connected from this pin to GND for stability."
      },
      {
        "pin_number": "5",
        "pin_name": "PG",
        "type": "O",
        "description": "Open-drain power-good indicator pin for the LDO output voltage. A 10-kΩ to 100-kΩ external pullup resistor is required. This pin can be left floating or connected to GND if not used."
      },
      {
        "pin_number": "6",
        "pin_name": "SS_CTRL",
        "type": "I",
        "description": "Soft-start control pin. Connect this pin either to GND or IN to change the NR/SS capacitor charging current. If a CNR/SS capacitor is not used, SS_CTRL must be connected to GND to avoid output overshoot."
      },
      {
        "pin_number": "Thermal pad",
        "pin_name": "Thermal pad",
        "type": "—",
        "description": "Connect the thermal pad to the printed circuit board (PCB) ground plane."
      }
    ]
  },
