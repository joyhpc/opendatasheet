      {
        "pin_number": "WSON:2, SOT:-",
        "pin_name": "MODE",
        "type": "I",
        "description": "This pin is only available at WSON package option. MODE pin = High forces the device to operate in fixed-frequency PWM mode. MODE pin = Low enables the power save mode with automatic transition from PFM mode to fixed-frequency PWM mode."
      },
