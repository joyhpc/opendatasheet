        "pin_number": "4",
        "pin_name": "VIN",
        "type": "I",
        "description": "Power in and control supply voltage."
      },
      {
        "pin_number": "5",
        "pin_name": "GND",
        "type": "—",
        "description": "Ground."
      },
      {
        "pin_number": "6",
        "pin_name": "LTCH",
        "type": "I",
        "description": "If low, the TPS2420 will attempt to restart after an overcurrent fault. If floating (high) the device will latch off after an overcurrent fault and will not attempt to restart until /EN or VIN is cycled off and on."
      },
      {
        "pin_number": "7",
        "pin_name": "IMAX",
        "type": "I",
        "description": "A resistor to ground sets the current-limit level."
      },
      {
        "pin_number": "8",
        "pin_name": "IFLT",
        "type": "I",
        "description": "A resistor to ground sets the fault current level."
      },
      {
        "pin_number": "9",
        "pin_name": "CT",
        "type": "I/O",
        "description": "A capacitor to ground sets the fault time."
      },
      {
        "pin_number": "10",
        "pin_name": "VOUT",
        "type": "O",
        "description": "Output to the load."
      },
      {
        "pin_number": "11",
        "pin_name": "VOUT",
        "type": "O",
        "description": "Output to the load."
      },
      {
        "pin_number": "12",
        "pin_name": "VOUT",
        "type": "O",
        "description": "Output to the load."
      },
      {
        "pin_number": "13",
        "pin_name": "IMON",
        "type": "O",
        "description": "A scaled down current which indicates the current through the device."
      },
      {
        "pin_number": "14",
        "pin_name": "/PG",
        "type": "O",
        "description": "Power Good low represents the output voltage is within 300 mV of the input voltage."
      },
      {
        "pin_number": "15",
        "pin_name": "/FLT",
        "type": "O",
        "description": "Fault low indicated the fault time has expired and the FET is switched off."
      },
      {
        "pin_number": "16",
        "pin_name": "/EN",
        "type": "I",
        "description": "Device is enabled when this pin is pulled low."
      }
    ]
  },
