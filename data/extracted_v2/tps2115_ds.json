    "pin_definitions": [
      {
        "pin_number": 1,
        "pin_name": "STAT",
        "type": "O",
        "description": "STAT is an open-drain output that is Hi-Z if the IN2 switch is ON. STAT pulls low if the IN1 switch is ON or if OUT is Hi-Z (i.e., EN is equal to logic 0)."
      },
      {
        "pin_number": 2,
        "pin_name": "D0",
        "type": "I",
        "description": "TTL and CMOS compatible input pins. Each pin has a 1-µA pullup resistor."
      },
      {
        "pin_number": 3,
        "pin_name": "D1",
        "type": "I",
        "description": "TTL and CMOS compatible input pins. Each pin has a 1-µA pullup resistor."
      },
      {
        "pin_number": 4,
        "pin_name": "ILIM",
        "type": "I",
        "description": "A resistor R(ILIM) from ILIM to GND sets the current limit IL to 250/R(ILIM) and 500/R(ILIM) for the TPS2114 and TPS2115, respectively."
      },
      {
        "pin_number": 5,
        "pin_name": "GND",
        "type": "I",
        "description": "Ground"
      },
      {
        "pin_number": 6,
        "pin_name": "IN2",
        "type": "I",
        "description": "Secondary power switch input. The IN2 switch can be enabled only if the IN2 supply is above the UVLO threshold and at least one supply exceeds the internal VDD UVLO."
      },
      {
        "pin_number": 7,
        "pin_name": "OUT",
        "type": "O",
        "description": "Power switch output"
      },
      {
        "pin_number": 8,
        "pin_name": "IN1",
        "type": "I",
        "description": "Primary power switch input. The IN1 switch can be enabled only if the IN1 supply is above the UVLO threshold and at least one supply exceeds the internal VDD UVLO."
      }
    ]
  },
